task.spawn(function()
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local breedRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("breedRequest")
local petFolder = workspace:WaitForChild("PlayerPens"):WaitForChild("1"):WaitForChild("Pets")

-- Danh sách công thức
local validRecipes = {
    {"Skeleton Giant Scorpion", "Lava Bear"},
    {"Phoenix", "Skeleton Crocodile"},
    {"Lightning Dragon", "Cerberus"},
    {"Red Panda", "Kitsune"},
    {"Red Panda", "Axolotl"}
}

local pairedPets = {} -- Lưu trữ ID các cặp đã chốt: { {guid1, guid2}, ... }
local usedGuids = {} -- Set kiểm tra GUID nào đã bị "khóa" (đã có chủ)

-- Hàm lấy giá trị Tên của Pet (Species Name)
-- Dựa vào ảnh của bạn, "Name" có thể là StringValue bên trong Pet hoặc là Attribute
local function getPetSpeciesName(petInstance)
    -- Thử cách 1: Nếu Name là 1 StringValue bên trong Pet
    local nameVal = petInstance:FindFirstChild("Name")
    if nameVal and nameVal:IsA("StringValue") then
        return nameVal.Value
    end

    -- Thử cách 2: Nếu Name là Attribute
    local attrName = petInstance:GetAttribute("Name")
    if attrName then return attrName end

    return nil
end

-- Hàm kiểm tra xem 2 tên pet có hợp lệ theo danh sách không
local function isMatch(name1, name2)
    
    for _, recipe in ipairs(validRecipes) do
        if (recipe[1] == name1 and recipe[2] == name2) or (recipe[1] == name2 and recipe[2] == name1) then
            return true
        end
    end
    return false
end

-- 2. Hàm quét và đóng gói cặp cho các pet chưa có chủ
local function updatePairs()
    local availablePets = {}

    -- Lọc ra các pet CHƯA BỊ KHÓA CẶP
    for _, pet in ipairs(petFolder:GetChildren()) do
        local guid = pet.Name -- Tên file chính là id/GUID
        if not usedGuids[guid] then
            local speciesName = getPetSpeciesName(pet)
            if speciesName then
                table.insert(availablePets, {instance = pet, guid = guid, species = speciesName})
            end
    
        end
    end

    -- Tiến hành ghép cặp cho các pet rảnh rỗi (Pet lẻ sẽ tự động bị bỏ qua do không tìm được match)
    for i = 1, #availablePets do
        local p1 = availablePets[i]
        if not usedGuids[p1.guid] then
            for j = i + 1, #availablePets do
                
                local p2 = availablePets[j]
                if not usedGuids[p2.guid] then
                    if isMatch(p1.species, p2.species) then
                        -- Chốt đơn cặp này! -- Ghi nhớ ID mãi mãi
                        table.insert(pairedPets, {p1.guid, p2.guid})
                        usedGuids[p1.guid] = true
                        usedGuids[p2.guid] = true
                  
                        break -- Tìm được rồi thì ngưng, chuyển sang p1 tiếp theo
                    end
                end
            end
        end
    end
end

-- 3. Vòng lặp chính hoạt động liên tục
task.spawn(function()
    while task.wait() do
        updatePairs() -- Liên tục check xem có pet mới nào rơi vào để ghép cặp không

        -- Nếu danh sách rỗng, chờ 1 giây rồi check lại để tránh lag game
        if #pairedPets == 0 then
            task.wait(0.5)
            continue
        end

        -- Copy danh sách cặp ra để xáo trộn (Random lại các cặp từ đầu như yêu cầu)
        local shuffledPairs = {}
        for _, pair in ipairs(pairedPets) do
            table.insert(shuffledPairs, pair)
        end

        -- Thuật toán xáo trộn ngẫu nhiên (Fisher-Yates)
        for i = #shuffledPairs, 2, -1 do
            local j = math.random(i)
      
            shuffledPairs[i], shuffledPairs[j] = shuffledPairs[j], shuffledPairs[i]
        end

        -- Bắt đầu lặp qua danh sách đã xáo trộn để invoke remote
        for _, pair in ipairs(shuffledPairs) do
            local guid1, guid2 = pair[1], pair[2]

            -- Check xem 2 file pet này CÒN TỒN TẠI trong workspace không
        
            local pet1 = petFolder:FindFirstChild(guid1)
            local pet2 = petFolder:FindFirstChild(guid2)

            if pet1 and pet2 then
                -- Cả 2 đều có mặt -> Tiến hành phối giống
                local args = {
                 
                    pet1,
                    pet2,
                    vector.create(-1.4219087362289429, 12, -3068.895751953125),
                    vector.create(-20.865795135498047, 12, -3037.915283203125)
                }

                -- Dùng pcall bọc lại để nếu game có lag hay lỗi remote thì script không bị đứng
                pcall(function()
                    breedRemote:InvokeServer(unpack(args))
                end)

                task.wait(0.05) -- Đợi 0.5s trước khi phối cặp tiếp theo
       
            else
                -- Một trong hai (hoặc cả hai) bị mất khỏi workspace -> Bỏ qua (Skip)
                -- Script sẽ không làm gì, tự động sang cặp tiếp theo.
                -- Cặp này sẽ được check lại ở vòng lặp lớn sau.
            end
        end
    end
end)

end)
