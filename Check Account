local function createStatusSection(label, yPos, id, activeColor)
    createLabel(label, UDim2.new(0.05, 0, yPos, 0), Main, 11)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.2, 0, 0, 30); btn.Position = UDim2.new(0.05, 0, yPos + 0.035, 0)
    btn.Text = "ON"; btn.BackgroundColor3 = activeColor; btn.TextColor3 = Color3.new(1,1,1); btn.Parent = Main; Instance.new("UICorner", btn)
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.65, 0, 0, 30); box.Position = UDim2.new(0.3, 0, yPos + 0.035, 0); box.PlaceholderText = "Tin nhắn..."; box.BackgroundColor3 = Color3.fromRGB(40,40,40); box.TextColor3 = Color3.new(1,1,1); box.TextSize = 12; box.Parent = Main; Instance.new("UICorner", box)
    btn.MouseButton1Click:Connect(function()
        statusConfigs[id].enabled = not statusConfigs[id].enabled
        btn.Text = statusConfigs[id].enabled and "ON" or "OFF"
        btn.BackgroundColor3 = statusConfigs[id].enabled and activeColor or Color3.fromRGB(70, 70, 70)
    end)
    box:GetPropertyChangedSignal("Text"):Connect(function() statusConfigs[id].msg = box.Text end)
end

