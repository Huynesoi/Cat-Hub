local function createLabel(txt, pos, parent, size)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0.9, 0, 0, 20); l.Position = pos; l.Text = txt
    l.TextColor3 = Color3.fromRGB(200, 200, 200); l.TextXAlignment = Enum.TextXAlignment.Left
    l.BackgroundTransparency = 1; l.Font = Enum.Font.GothamBold; l.TextSize = size or 12; l.Parent = parent
end

