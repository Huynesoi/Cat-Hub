local function createToggle(txt, pos, callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.43, 0, 0, 35); b.Position = pos; b.Text = txt; b.BackgroundColor3 = Color3.fromRGB(50, 50, 50); b.TextColor3 = Color3.new(1, 1, 1); b.Parent = Main; Instance.new("UICorner", b)
    local state = false
    b.MouseButton1Click:Connect(function()
        state = not state; b.BackgroundColor3 = state and Color3.fromRGB(155, 89, 182) or Color3.fromRGB(50, 50, 50); callback(state)
    end)
end
createToggle("ẨN TÊN", UDim2.new(0.05, 0, 0.65, 0), function(s) isHideName = s end)
createToggle("ẨN GAME", UDim2.new(0.52, 0, 0.65, 0), function(s) isHideGame = s end)

local Go = Instance.new("TextButton")
Go.Size = UDim2.new(0.9, 0, 0, 50); Go.Position = UDim2.new(0.05, 0, 0.85, 0); Go.Text = "CẬP NHẬT / THEO DÕI"; Go.BackgroundColor3 = Color3.fromRGB(255, 165, 0); Go.TextColor3 = Color3.new(1, 1, 1); Go.Font = Enum.Font.GothamBold; Go.Parent = Main; Instance.new("UICorner", Go)

Go.MouseButton1Click:Connect(function()
    local text = PlayerBox.Text
    local wbKey = WebhookBox.Text:lower()
    if text == "" or not Go.Active then return end
    
    Go.Active = false
    Go.Text = "ĐANG XỬ LÝ..."
    
    task.spawn(function()
        local isRemove = text:lower():sub(1,7) == "remove "
        local target = isRemove and text:sub(8) or text
        
        local success, uRes = pcall(function()
            return req({ Url = "https://users.roblox.com/v1/usernames/users", Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({usernames = {target}}) })
        end)

        if success and uRes and uRes.StatusCode == 200 then
            local uData = HttpService:JSONDecode(uRes.Body)
            if uData.data and #uData.data > 0 then
                pcall(function()
                    req({
                        Url = CLOUDFLARE_URL,
                        Method = "POST",
                        Headers = {["Content-Type"] = "application/json"},
                        Body = HttpService:JSONEncode({
                            targetId = uData.data[1].id,
                            targetName = uData.data[1].name,
                            action = isRemove and "remove" or "add",
                            statusConfigs = statusConfigs,
                            hideName = isHideName,
                            hideGame = isHideGame,
                            d = dBox.Text, h = hBox.Text, m = mBox.Text,
                            webhookKey = wbKey -- Gửi thêm khóa Webhook (w1, w2,...)
                        })
                    })
                end)
                Go.Text = "THÀNH CÔNG!"
            else Go.Text = "SAI TÊN PLAYER!" end
        else Go.Text = "LỖI KẾT NỐI!" end
        
        task.wait(1.5)
        Go.Text = "CẬP NHẬT / THEO DÕI"
        Go.Active = true
    end)
end)
