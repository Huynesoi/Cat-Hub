---------------------------------------------------------
-- 0. HÀM TRỢ GIÚP LẤY MÀU CỦA VẬT PHẨM
---------------------------------------------------------
local function getItemColor(item)
    -- Màu dự phòng nếu không tìm thấy màu hợp lệ
    local defaultColor = Color3.fromRGB(255, 255, 255) 

    if item:IsA("BasePart") then
        return item.Color -- Lấy trực tiếp màu của Part
    elseif item:IsA("Model") then
        -- Nếu là Model, cố gắng tìm Part chính để lấy màu
        if item.PrimaryPart then
            return item.PrimaryPart.Color
        else
            -- Nếu không có PrimaryPart, tìm Part đầu tiên nó thấy bên trong
            local firstPart = item:FindFirstChildWhichIsA("BasePart", true)
            if firstPart then
                return firstPart.Color
            end
        end
    end
    
    return defaultColor
end

---------------------------------------------------------
-- 1. TÍNH NĂNG ESP ĐỒNG BỘ MÀU VẬT PHẨM
---------------------------------------------------------
local function createESP(item)
    if (item:IsA("BasePart") or item:IsA("Model")) and not item:FindFirstChild("Item_Highlight_ESP") then
        
        -- Lấy màu của chính vật phẩm
        local mainColor = getItemColor(item)

        -- Tạo Highlight
        local highlight = Instance.new("Highlight")
        highlight.Name = "Item_Highlight_ESP"
        highlight.Adornee = item
        highlight.FillColor = mainColor -- Màu nền đồng bộ
        highlight.FillTransparency = 0.6 -- Hơi trong suốt để nhìn rõ vật phẩm
        highlight.OutlineColor = mainColor -- Viền đồng bộ (Hoặc Color3.new(1,1,1) nếu muốn viền trắng)
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = item

        -- Tạo BillboardGui (Tên vật phẩm)
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "Item_Text_ESP"
        billboard.Adornee = item
        billboard.Size = UDim2.new(0, 120, 0, 40)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true

        local textLabel = Instance.new("TextLabel")
        textLabel.Parent = billboard
        textLabel.BackgroundTransparency = 1
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.Text = "[ " .. item.Name .. " ]"
        textLabel.TextColor3 = mainColor -- Màu chữ đồng bộ
        textLabel.TextStrokeTransparency = 0 -- Giữ viền đen cho chữ để dễ đọc trên mọi nền
        textLabel.TextScaled = true
        textLabel.Font = Enum.Font.Code
        
        billboard.Parent = item
    end
end

-- Khởi tạo ESP cho toàn bộ Items
if itemsFolder then
    for _, obj in pairs(itemsFolder:GetChildren()) do
        createESP(obj)
    end

    itemsFolder.ChildAdded:Connect(function(obj)
        task.wait(0.1) 
        createESP(obj)
    end)
else
    warn("Không tìm thấy thư mục 'Items' trong Workspace!")
end

