task.spawn(function()
-- AntiLag LocalScript
-- Place in: StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

local Config = {
	Enabled = true,          -- trạng thái mặc định
	ToggleKey = Enum.KeyCode.F6,

	-- an toàn: không đụng vào model có Humanoid/AnimationController
	SkipCharacters = true,

	-- tối ưu nền
	DisableGlobalShadows = true,
	DisablePostEffects = true,

	-- tối ưu workspace
	DisablePartShadows = true,
	DisableParticles = true,
	DisableTrails = true,
	DisableBeams = true,
	DisableFireSmokeSparkles = true,
}

local saved = setmetatable({}, { __mode = "k" })
local connections = {}

local function isCharacterLike(inst)
	if not Config.SkipCharacters then
		return false
	end

	local model = inst:FindFirstAncestorOfClass("Model")
	if not model then
		return false
	end

	return model:FindFirstChildOfClass("Humanoid") ~= nil
		or model:FindFirstChildOfClass("AnimationController") ~= nil
end

local function saveProp(inst, prop)
	local data = saved[inst]
	if not data then
		data = {}
		saved[inst] = data
	end

	if data[prop] == nil then
		local ok, value = pcall(function()
			return inst[prop]
		end)
		if ok then
			data[prop] = value
		end
	end
end

local function setIfPossible(inst, prop, value)
	local ok = pcall(function()
		inst[prop] = value
	end)
	return ok
end

local function restoreInstance(inst)
	local data = saved[inst]
	if not data then
		return
	end

	for prop, value in pairs(data) do
		pcall(function()
			inst[prop] = value
		end)
	end
	saved[inst] = nil
end

local function processInstance(inst, enabled)
	if not inst or inst.Parent == nil then
		return
	end

	if isCharacterLike(inst) then
		return
	end

	if enabled then
		if Config.DisablePartShadows and inst:IsA("BasePart") then
			saveProp(inst, "CastShadow")
			setIfPossible(inst, "CastShadow", false)
		end

		if Config.DisableParticles and inst:IsA("ParticleEmitter") then
			saveProp(inst, "Enabled")
			setIfPossible(inst, "Enabled", false)
			pcall(function()
				inst:Clear()
			end)
		end

		if Config.DisableTrails and inst:IsA("Trail") then
			saveProp(inst, "Enabled")
			setIfPossible(inst, "Enabled", false)
		end

		if Config.DisableBeams and inst:IsA("Beam") then
			saveProp(inst, "Enabled")
			setIfPossible(inst, "Enabled", false)
		end

		if Config.DisableFireSmokeSparkles then
			if inst:IsA("Fire") or inst:IsA("Smoke") or inst:IsA("Sparkles") then
				saveProp(inst, "Enabled")
				setIfPossible(inst, "Enabled", false)
			end
		end

		if Config.DisablePostEffects and (inst:IsA("PostEffect")) then
			saveProp(inst, "Enabled")
			setIfPossible(inst, "Enabled", false)
		end
	else
		restoreInstance(inst)
	end
end

local function applyAntiLag(enabled)
	enabled = enabled and true or false

	if Config.DisableGlobalShadows then
		saveProp(Lighting, "GlobalShadows")
		setIfPossible(Lighting, "GlobalShadows", not not (not enabled and saved[Lighting] and saved[Lighting].GlobalShadows or false))
		if enabled then
			setIfPossible(Lighting, "GlobalShadows", false)
		end
	end

	if Config.DisablePostEffects then
		for _, obj in ipairs(Lighting:GetDescendants()) do
			processInstance(obj, enabled)
		end
		local camera = Workspace.CurrentCamera
		if camera then
			for _, obj in ipairs(camera:GetDescendants()) do
				processInstance(obj, enabled)
			end
		end
	end

	for _, obj in ipairs(Workspace:GetDescendants()) do
		processInstance(obj, enabled)
	end

	if enabled then
		for _, obj in ipairs(Workspace:GetDescendants()) do
			processInstance(obj, true)
		end
	end

	Config.Enabled = enabled
end

local function bindWatchers()
	table.insert(connections, Workspace.DescendantAdded:Connect(function(obj)
		if Config.Enabled then
			processInstance(obj, true)
		end
	end))

	table.insert(connections, Lighting.DescendantAdded:Connect(function(obj)
		if Config.Enabled then
			processInstance(obj, true)
		end
	end))

	if Workspace.CurrentCamera then
		table.insert(connections, Workspace.CurrentCamera.DescendantAdded:Connect(function(obj)
			if Config.Enabled then
				processInstance(obj, true)
			end
		end))
	end
end

local function refresh()
	applyAntiLag(Config.Enabled)
end

bindWatchers()
refresh()

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then
		return
	end

	if input.KeyCode == Config.ToggleKey then
		Config.Enabled = not Config.Enabled
		applyAntiLag(Config.Enabled)
	end
end)
end)
