task.spawn(function()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local RENDER_DISTANCE = 70
local MIN_SIZE = Vector3.new(0.001, 0.001, 0.001) -- Roblox sẽ tự động giới hạn ở mức nhỏ nhất có thể của Part

local entityList = {}
local charCache = {}

-- Tìm RootPart của Character
local function getRoot(char)
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart or char:FindFirstChildWhichIsA("BasePart")
end

-- Hàm Ẩn và thu nhỏ Character
local function hideCharacter(char)
    if not char then return end
    if charCache[char] and charCache[char].isHidden then return end
    if not charCache[char] then charCache[char] = { OriginalSizes = {}, isHidden = false } end

    charCache[char].isHidden = true

    -- 1. Dừng toàn bộ Animation đang chạy
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                track:Stop()
            end
        end
    end

    -- 2. Ẩn Face, Phụ kiện và thu nhỏ Hitbox/Parts
    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("BasePart") then
            -- Lưu lại size gốc trước khi đổi
            if not charCache[char].OriginalSizes[desc] then
                charCache[char].OriginalSizes[desc] = desc.Size
            end
            desc.Size = MIN_SIZE
            desc.CanCollide = false -- Tắt va chạm để mượt hơn
            desc.LocalTransparencyModifier = 1 -- Làm vô hình (chỉ Client)
            
        elseif desc:IsA("Decal") and desc.Name == "face" then
            desc.Transparency = 1
            
        elseif desc:IsA("Accessory") then
            local handle = desc:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                handle.LocalTransparencyModifier = 1
            end
        end
    end
end

-- Hàm Hiển thị và phục hồi Character
local function showCharacter(char)
    if not char or not charCache[char] or not charCache[char].isHidden then return end
    charCache[char].isHidden = false

    -- Phục hồi lại toàn bộ trạng thái
    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("BasePart") and charCache[char].OriginalSizes[desc] then
            desc.Size = charCache[char].OriginalSizes[desc]
            desc.CanCollide = true
            desc.LocalTransparencyModifier = 0
            
        elseif desc:IsA("Decal") and desc.Name == "face" then
            desc.Transparency = 0
            
        elseif desc:IsA("Accessory") then
            local handle = desc:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                handle.LocalTransparencyModifier = 0
            end
        end
    end
end

