task.spawn(function()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local EXTREME_DISTANCE = 100 -- Tắt bóng, hiệu ứng, tên, tàng hình Torso
local VISUAL_DISTANCE = 70   -- Tắt/Bật hình ảnh phụ kiện và Animation
local HITBOX_DISTANCE = 10   -- Thu nhỏ/Khôi phục kích thước Hitbox
local MIN_SIZE = Vector3.new(0.001, 0.001, 0.001)

local entityList = {}
local charCache = {}

-- Danh sách các class gây lag (Hiệu ứng hạt)
local effectClasses = {
    ["ParticleEmitter"] = true, ["Trail"] = true, ["Beam"] = true,
    ["Fire"] = true, ["Smoke"] = true, ["Sparkles"] = true
}

local function getRoot(char)
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart or char:FindFirstChildWhichIsA("BasePart")
end

local function isTorso(partName)
    return partName == "Torso" or partName == "UpperTorso" or partName == "LowerTorso"
end

-- Lưu toàn bộ dữ liệu gốc của Character trước khi can thiệp
local function saveOriginalData(char)
    if not charCache[char] then
        local hum = char:FindFirstChildOfClass("Humanoid")
        charCache[char] = { 
            Sizes = {}, 
            Shadows = {}, 
            Effects = {}, 
            DisplayType = hum and hum.DisplayDistanceType or Enum.HumanoidDisplayDistanceType.Viewer,
            VisualsHidden = false, 
            HitboxMinimized = false,
            ExtremeHidden = false
        }
    end
    
    local cache = charCache[char]
    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("BasePart") then
            if not cache.Sizes[desc] then cache.Sizes[desc] = desc.Size end
            if cache.Shadows[desc] == nil then cache.Shadows[desc] = desc.CastShadow end
        elseif effectClasses[desc.ClassName] then
            if cache.Effects[desc] == nil then cache.Effects[desc] = desc.Enabled end
        end
    end
end

-- Tối ưu cực đại (Quá 100 studs)
local function setExtreme(char, isExtreme)
    local cache = charCache[char]
    if not char or not cache then return end

    -- Ẩn/Hiện Tên trên đầu
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.DisplayDistanceType = isExtreme and Enum.HumanoidDisplayDistanceType.None or cache.DisplayType
    end

    for _, desc in pairs(char:GetDescendants()) do
        -- Tắt đổ bóng và tàng hình Torso
        if desc:IsA("BasePart") then
            desc.CastShadow = isExtreme and false or (cache.Shadows[desc] == nil and true or cache.Shadows[desc])
            if isTorso(desc.Name) then
                desc.LocalTransparencyModifier = isExtreme and 1 or 0
            end
        -- Tắt hiệu ứng lòe loẹt
        elseif effectClasses[desc.ClassName] then
            desc.Enabled = isExtreme and false or (cache.Effects[desc] == nil and true or cache.Effects[desc])
        end
    end
end

-- Quản lý Hình ảnh & Animation (Mốc 50 studs)
local function setVisuals(char, isVisible)
    if not char then return end

    if not isVisible then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            local animator = humanoid:FindFirstChildOfClass("Animator")
            if animator then
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                    track:Stop()
                end
            end
        end
    end

    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("BasePart") and not isTorso(desc.Name) then
            desc.LocalTransparencyModifier = isVisible and 0 or 1
        elseif desc:IsA("Decal") and desc.Name == "face" then
            desc.Transparency = isVisible and 0 or 1
        elseif desc:IsA("Accessory") then
            local handle = desc:FindFirstChild("Handle")
            if handle and handle:IsA("BasePart") then
                handle.LocalTransparencyModifier = isVisible and 0 or 1
            end
        end
    end
end

-- Quản lý Kích thước Hitbox (Mốc 10 studs)
local function setHitbox(char, isNormal)
    local cache = charCache[char]
    if not char or not cache then return end

    for _, desc in pairs(char:GetDescendants()) do
        if desc:IsA("BasePart") and not isTorso(desc.Name) then
            if isNormal then
                if cache.Sizes[desc] then desc.Size = cache.Sizes[desc] end
                desc.CanCollide = true
            else
                desc.Size = MIN_SIZE
                desc.CanCollide = false
            end
        end
    end
end

-- Cập nhật danh sách (mỗi 3s)
task.spawn(function()
    while task.wait(3) do
        table.clear(entityList)
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                table.insert(entityList, player.Character)
            end
        end
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                table.insert(entityList, obj)
            end
        end
    end
end)

-- Vòng lặp Core kiểm tra khoảng cách (mỗi 0.2s)
task.spawn(function()
    while task.wait(0.2) do
        local myChar = LocalPlayer.Character
        local myRoot = myChar and getRoot(myChar)
        
        if not myRoot then continue end
        local myPos = myRoot.Position

        for _, entity in pairs(entityList) do
            if entity and entity.Parent then
                local targetRoot = getRoot(entity)
                if targetRoot then
                    saveOriginalData(entity)
                    local cache = charCache[entity]
                    local distance = (myPos - targetRoot.Position).Magnitude
                    
                    -- Mốc 100: Hiệu ứng, Đổ bóng, Tên, Torso
                    if distance > EXTREME_DISTANCE then
