-- Vòng lặp kiểm tra khoảng cách (Chạy mỗi 0.2 giây để tối ưu hiệu suất)
task.spawn(function()
    while task.wait(0.2) do
        local myChar = LocalPlayer.Character
        local myRoot = myChar and getRoot(myChar)
        
        if not myRoot then continue end
        local myPos = myRoot.Position

        for _, entity in pairs(entityList) do
            if entity and entity.Parent then -- Đảm bảo entity chưa bị xóa khỏi map
                local targetRoot = getRoot(entity)
                if targetRoot then
                    local distance = (myPos - targetRoot.Position).Magnitude
                    
