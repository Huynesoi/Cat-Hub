                    else
                        if cache.ExtremeHidden then setExtreme(entity, false); cache.ExtremeHidden = false end
                    end

                    -- Mốc 50: Animation & Hình ảnh ngoại trừ Torso
                    if distance > VISUAL_DISTANCE then
                        if not cache.VisualsHidden then setVisuals(entity, false); cache.VisualsHidden = true end
                    else
                        if cache.VisualsHidden then setVisuals(entity, true); cache.VisualsHidden = false end
                    end

                    -- Mốc 10: Thu nhỏ/Phóng to Hitbox
                    if distance > HITBOX_DISTANCE then
                        if not cache.HitboxMinimized then setHitbox(entity, false); cache.HitboxMinimized = true end
                    else
                        if cache.HitboxMinimized then setHitbox(entity, true); cache.HitboxMinimized = false end
                    end
                end
            end
        end
    end
end)

print("Đã chạy Script Anti-Lag Siêu Cấp (3 Mốc: 100/50/10)!")

