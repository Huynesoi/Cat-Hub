task.spawn(function()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

-- Biến Trạng Thái
local isRunning = false  -- Trạng thái tổng của Script (Bật/Tắt qua GUI)
local canFarm = false    -- Trạng thái cho phép Spam & Tele (Tạm dừng khi chết)
local isDead = false

-- Bảng đếm số lần tele (Tự dọn rác khi cây bị xóa)
local treeTracker = {}
setmetatable(treeTracker, {__mode = "k"})

-- ==========================================
-- 1. TẠO GUI GIAO DIỆN CHÍNH
-- ==========================================
local guiName = "TreeAutoFarmGUI_Huynesoi"
local targetGui = pcall(function() return CoreGui end) and CoreGui or LocalPlayer:WaitForChild("PlayerGui")

-- Xóa GUI cũ nếu lỡ chạy lại script 2 lần
if targetGui:FindFirstChild(guiName) then
    targetGui:FindFirstChild(guiName):Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = guiName
ScreenGui.Parent = targetGui

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 200, 0, 100)
MainFrame.Position = UDim2.new(0.5, -100, 0.1, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 2
MainFrame.Parent = ScreenGui
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể kéo thả GUI

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.Text = "Tree Auto Farm"
Title.Font = Enum.Font.SourceSansBold
Title.TextSize = 18
Title.Parent = MainFrame

local ToggleButton = Instance.new("TextButton")
ToggleButton.Size = UDim2.new(0.8, 0, 0, 40)
ToggleButton.Position = UDim2.new(0.1, 0, 0.45, 0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.Text = "OFF"
ToggleButton.Font = Enum.Font.SourceSansBold
ToggleButton.TextSize = 20
ToggleButton.Parent = MainFrame

-- ==========================================
-- 2. CÁC HÀM XỬ LÝ SKILL
-- ==========================================
local function fireSkillV()
    local argsV = {
        "DF_BrachioBrachio_V",
        {MouseHit = CFrame.new(2210.47, 32.32, 874.55, 1, 0, 0, 0, 1, 0, 0, 0, 1)}
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsV)) end)
end

local function fireSkillE()
    local argsE = {
        "DF_BrachioBrachio_E",
        {MouseHit = CFrame.new(2121.00, 51.18, 561.77, 1, 0, 0, 0, 1, 0, 0, 0, 1), Type = "Down"}
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsE)) end)
end

-- ==========================================
-- 3. XỬ LÝ NHÂN VẬT & LOGIC KHỞI ĐỘNG LẠI
-- ==========================================
local function startFarmSequence()
    if not isRunning then return end
    canFarm = false -- Khóa không cho tele vội
    
    task.wait(2) -- Đợi 2s để nhân vật load hẳn vào map
    if isRunning and not isDead then
        fireSkillV()
        task.wait(1) -- Sau 1s mới kích hoạt Spam E và Tele
        if isRunning and not isDead then
            canFarm = true
        end
    end
end

local function setupCharacter(character)
    isDead = false
    local humanoid = character:WaitForChild("Humanoid")
    
    humanoid.Died:Connect(function()
        isDead = true
        canFarm = false
        treeTracker = {} -- Dọn sạch bộ đếm khi chết
        setmetatable(treeTracker, {__mode = "k"})
    end)

    -- Bắt đầu chuỗi logic farm (Dùng V -> chờ 1s -> Spam E & Tele)
    task.spawn(startFarmSequence)
end

if LocalPlayer.Character then setupCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupCharacter)

-- ==========================================
-- 4. LOGIC GIAO DIỆN BẬT / TẮT
-- ==========================================
ToggleButton.MouseButton1Click:Connect(function()
    isRunning = not isRunning
    if isRunning then
        ToggleButton.Text = "ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        -- Nếu nhân vật đang sống, khởi động ngay chuỗi Farm
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.Health > 0 then
            task.spawn(startFarmSequence)
        end
    else
        ToggleButton.Text = "OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        canFarm = false
    end
end)

-- ==========================================
-- 5. LUỒNG SPAM SKILL E
-- ==========================================
task.spawn(function()
    while true do
        if isRunning and canFarm and not isDead then
            fireSkillE()
        end
        task.wait() -- Tốc độ spam siêu tốc theo Frame
    end
end)

-- ==========================================
-- 6. LUỒNG TELEPORT & QUẢN LÝ CÂY
-- ==========================================
task.spawn(function()
    while true do
        if isRunning and canFarm and not isDead and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Bước 1: Quét và tạo danh sách
                local treesToFarm = {}
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and string.find(obj.Name:lower(), "tree") then
                        table.insert(treesToFarm, obj)
                    end
                end

                -- Bước 2: Dịch chuyển theo thứ tự
                if #treesToFarm > 0 then
                    for _, tree in ipairs(treesToFarm) do
                        -- Kiểm tra liên tục xem có bị tắt tool hoặc chết không
                        if not (isRunning and canFarm and not isDead) then break end
                        
                        if tree and tree.Parent then
                            -- Đếm số lần tele
                            treeTracker[tree] = (treeTracker[tree] or 0) + 1
                            
                            -- ĐỔI TÊN THÀNH BLACKLIST NẾU QUÁ 5 LẦN
                            if treeTracker[tree] > 5 then
                                pcall(function()
                                    tree.Name = "BlackListNil"
                                end)
                                treeTracker[tree] = nil
                                continue -- Bỏ qua và sang cây kế tiếp luôn
                            end

                            -- Teleport
                            pcall(function()
                                root.CFrame = tree:GetPivot()
                            end)
                            
                            task.wait(0.06) -- Delay theo đúng yêu cầu
                        else
                            treeTracker[tree] = nil
                        end
                    end
                end
                table.clear(treesToFarm)
            end
        end
        task.wait(0.2) -- Nghỉ ngắn trước khi quét lại để không bị đơ game
    end
end)


end)

