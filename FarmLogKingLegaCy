task.spawn(function()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local isDead = false
local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

-- Cấu hình
local TELEPORT_DELAY = 0.06 -- Tốc độ nhảy cây
local SCAN_INTERVAL = 0.5 -- Thời gian nghỉ giữa mỗi lần quét lại toàn bản đồ

-- 1. Luồng Spam Skill E (Tối ưu để không gây lag)
task.spawn(function()
    local argsE = {
        "DF_BrachioBrachio_E",
        {
            MouseHit = CFrame.new(2121.0048828125, 51.182037353515625, 561.7747802734375, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            Type = "Down"
        }
    }
    while true do
        if not isDead then
            pcall(function() 
                skillRemote:InvokeServer(unpack(argsE)) 
            end)
        end
        task.wait() -- Spam theo frame (nhanh nhất có thể)
    end
end)

-- 2. Xử lý hồi sinh
local function onCharacterAdded(character)
    isDead = true
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function() isDead = true end)

    task.wait(5)
    
    local argsV = {
        "DF_BrachioBrachio_V",
        {
            MouseHit = CFrame.new(2210.47216796875, 32.324493408203125, 874.5543212890625, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        }
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsV)) end)
    isDead = false
end

if LocalPlayer.Character then task.spawn(onCharacterAdded, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

-- 3. Vòng lặp Teleport (Bản Fix lỗi bỏ sót và chậm)
task.spawn(function()
    while true do
        if not isDead and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Tối ưu quét: Chỉ tìm Model và lọc tên ngay lập tức
                local treesToFarm = {}
                local allDescendants = workspace:GetDescendants()
                
                for i = 1, #allDescendants do
                    local obj = allDescendants[i]
                    if obj:IsA("Model") and string.find(obj.Name:lower(), "tree") then
                        table.insert(treesToFarm, obj)
                    end
                end

                -- Thực hiện Teleport theo danh sách đã "chốt"
                if #treesToFarm > 0 then
                    for _, tree in ipairs(treesToFarm) do
                        if isDead then break end
                        
                        -- Kiểm tra kỹ xem cây còn thật sự ở đó không
                        if tree and tree.Parent and tree:FindFirstChildWhichIsA("BasePart", true) then
                            pcall(function()
                                root.CFrame = tree:GetPivot()
                            end)
                            task.wait(TELEPORT_DELAY)
                        end
                    end
                end
                
                -- Giải phóng bộ nhớ cho bảng cũ
                table.clear(treesToFarm)
                treesToFarm = nil
            end
        end
        -- Nghỉ một chút để CPU "thở" trước khi quét đợt tiếp theo (Chống lag cực hiệu quả)
        task.wait(SCAN_INTERVAL)
    end
end)

end)

