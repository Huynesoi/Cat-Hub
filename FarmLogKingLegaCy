task.spawn(function()
--// disguised local script

local _S = game:GetService
local _P = _S("Players").LocalPlayer
local _R = _S("ReplicatedStorage")
local _U = _S("UserInputService")

--// refs
local _C, _H, _Root
local function _r()
    _C = _P.Character or _P.CharacterAdded:Wait()
    _H = _C:FindFirstChildOfClass("Humanoid")
    _Root = _C:FindFirstChild("HumanoidRootPart") or _C:FindFirstChild("Torso")
end
_r()
_P.CharacterAdded:Connect(function()
    task.wait(0.2)
    _r()
end)

--// gui
local g = Instance.new("ScreenGui")
g.Name = "SysCore"
g.ResetOnSpawn = false
g.Parent = _P:WaitForChild("PlayerGui")

local b = Instance.new("TextButton")
b.Size = UDim2.new(0,120,0,40)
b.Position = UDim2.new(0.05,0,0.8,0)
b.Text = "OFF"
b.Parent = g

local f = Instance.new("Frame")
f.Size = UDim2.new(0,200,0,120)
f.Position = UDim2.new(0.05,0,0.6,0)
f.BackgroundTransparency = 0.3
f.Parent = g

-- drag
do
    local d, s, p
    b.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            d = i
            s = i.Position
            p = b.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then d = nil end
            end)
        end
    end)
    _U.InputChanged:Connect(function(i)
        if i == d then
            local delta = i.Position - s
            b.Position = UDim2.new(p.X.Scale, p.X.Offset + delta.X, p.Y.Scale, p.Y.Offset + delta.Y)
        end
    end)
end

--// remote
local _F = _R:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

local function _V()
    local a = {
        "DF_BrachioBrachio_V",
        {MouseHit = CFrame.new(2210.4721,32.32449,874.5543)}
    }
    pcall(function() _F:InvokeServer(unpack(a)) end)
end

local function _E()
    local a = {
        "DF_BrachioBrachio_E",
        {
            MouseHit = CFrame.new(2121.0048,51.18203,561.7747),
            Type = "Down"
        }
    }
    pcall(function() _F:InvokeServer(unpack(a)) end)
end

--// tree scan
local _list = {}
local _black = {}

local function _scan()
    _list = {}
    for _,v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") then
            local n = v.Name
            if string.find(string.lower(n),"tree") and not _black[v] then
                table.insert(_list,v)
            end
        end
    end
end

--// main
local _on = false

local function _tp(m)
    if not _Root then return end
    local p = m:GetPivot().Position
    _Root.CFrame = CFrame.new(p + Vector3.new(0,3,0))
end

local function _run()
    while _on do
        -- check EMode
        local eMode = workspace:FindFirstChild("Effects")
        local allowCheck = false
        if eMode and eMode:FindFirstChild("EMode") then
            allowCheck = true
        end

        _scan()

        for _,m in ipairs(_list) do
            if not _on then break end
            if not m or not m.Parent then continue end

            local tries = 0
            local removed = false

            repeat
                if not _on then break end

                _tp(m)
                _E()

                task.wait(0.06)

                if not m.Parent then
                    removed = true
                    break
                end

                tries += 1
            until tries >= 5

            if allowCheck and (not removed) then
                _black[m] = true
                pcall(function()
                    m.Name = "BlackListNil"
                end)
            end
        end

        task.wait()
    end
end

--// toggle
b.MouseButton1Click:Connect(function()
    _on = not _on
    b.Text = _on and "ON" or "OFF"

    if _on then
        task.spawn(function()
            _V()
            task.wait(1)
            while _on do
                _run()
                task.wait()
            end
        end)
    end
end)

--// reset when die
_H.Died:Connect(function()
    _on = false
    b.Text = "OFF"
end)
        if IsRunning and Character and Character:FindFirstChild("Humanoid") and Character.Humanoid.Health > 0 then
            -- Bước 1: Dùng Skill V
            UseSkill("DF_BrachioBrachio_V", CFrame.new(2210.47, 32.32, 874.55))
            
            task.wait(1)
            
            -- Bước 2: Quét danh sách và bắt đầu Teleport/Spam E
            local TreeList = GetTreeList()
            
            for _, tree in pairs(TreeList) do
                if not IsRunning or Character.Humanoid.Health <= 0 then break end
                if not tree or not tree.PrimaryPart then continue end

                -- Teleport tới cây
                Root.CFrame = tree:GetModelCFrame()
                
                -- Dùng Skill E
                UseSkill("DF_BrachioBrachio_E", CFrame.new(2121.00, 51.18, 561.77), "Down")
                
                -- Kiểm tra hiệu ứng EMode để xử lý Blacklist
                task.wait(0.06)
                
                local isEModeActive = workspace:FindFirstChild("Effects") and workspace.Effects:FindFirstChild("EMode")
                
                if isEModeActive then
                    -- Nếu có EMode (Skill đang trúng/hoạt động), kiểm tra xem cây có biến mất không
                    TeleportCount[tree] = (TeleportCount[tree] or 0) + 1
                    
                    if TeleportCount[tree] >= 5 then
                        Blacklist[tree] = true
                        tree.Name = "BlackListNil" -- Đổi tên để tránh trùng lặp
                        warn("Đã Blacklist model: " .. tree.Name)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)


end)

