task.spawn(function()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local isDead = false
local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

-- Hệ thống lưu trữ sử dụng Weak Tables để tự động dọn dẹp bộ nhớ
local treeTracker = {}
local blacklistedTrees = {}
setmetatable(treeTracker, {__mode = "k"}) -- Tự xóa dữ liệu nếu Instance bị Destroy
setmetatable(blacklistedTrees, {__mode = "k"})

local MAX_ATTEMPTS = 5    
local TELEPORT_DELAY = 0.06

-- 1. Luồng Spam Skill E
task.spawn(function()
    local argsE = {
        "DF_BrachioBrachio_E",
        {
            MouseHit = CFrame.new(2121.0048828125, 51.182037353515625, 561.7747802734375, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            Type = "Down"
        }
    }
    while true do
        if not isDead then
            pcall(function() skillRemote:InvokeServer(unpack(argsE)) end)
        end
        task.wait() 
    end
end)

-- 2. Xử lý hồi sinh
local function onCharacterAdded(character)
    isDead = true
    treeTracker = {} 
    setmetatable(treeTracker, {__mode = "k"})
    
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function() isDead = true end)

    task.wait(5)
    
    local argsV = {
        "DF_BrachioBrachio_V",
        {
            MouseHit = CFrame.new(2210.47216796875, 32.324493408203125, 874.5543212890625, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        }
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsV)) end)
    isDead = false
end

if LocalPlayer.Character then task.spawn(onCharacterAdded, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

-- 3. Vòng lặp Teleport chính (Đã gia cố chống dừng script)
task.spawn(function()
    while true do
        local success, err = pcall(function() -- Bọc toàn bộ để tránh lỗi dừng script
            if not isDead and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local treesToFarm = {}
                    
                    -- Quét nhanh hơn bằng cách giới hạn đối tượng
                    for _, obj in ipairs(workspace:GetChildren()) do -- Thử GetChildren trước cho nhanh
                        if obj:IsA("Model") and string.find(obj.Name:lower(), "tree") and not blacklistedTrees[obj] then
                            table.insert(treesToFarm, obj)
                        end
                    end
                    
                    -- Nếu không tìm thấy ở ngoài, mới quét sâu vào Descendants
                    if #treesToFarm == 0 then
                        for _, obj in ipairs(workspace:GetDescendants()) do
                            if obj:IsA("Model") and string.find(obj.Name:lower(), "tree") and not blacklistedTrees[obj] then
                                table.insert(treesToFarm, obj)
                            end
                        end
                    end

                    if #treesToFarm > 0 then
                        for _, tree in ipairs(treesToFarm) do
                            if isDead or not tree.Parent then continue end
                            
                            treeTracker[tree] = (treeTracker[tree] or 0) + 1
                            
                            if treeTracker[tree] > MAX_ATTEMPTS then
                                blacklistedTrees[tree] = true
                                continue 
                            end

                            root.CFrame = tree:GetPivot()
                            task.wait(TELEPORT_DELAY)
                        end
                    end
                end
            end
        end)

        if not success then
            warn("Script gặp lỗi nhưng đã tự khởi động lại: " .. tostring(err))
        end
        
        task.wait(0.5) 
    end
end)



end)

