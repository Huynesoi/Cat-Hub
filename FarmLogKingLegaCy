local function onCharacterAdded(character)
    isDead = true
    currentTreeList = {} -- Xóa danh sách để reset lộ trình khi chết
    
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        isDead = true
    end)

    -- Đợi 5 giây sau khi respawn theo yêu cầu
    task.wait(5)
    
    -- Sử dụng Skill V trước khi bắt đầu lại
    local argsV = {
        "DF_BrachioBrachio_V",
        {
            MouseHit = CFrame.new(2210.47216796875, 32.324493408203125, 874.5543212890625, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        }
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsV)) end)
    
    isDead = false -- Mở khóa để bắt đầu farm
end

if LocalPlayer.Character then task.spawn(onCharacterAdded, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

-- 3. Vòng lặp Teleport theo danh sách Model có chữ "tree"
task.spawn(function()
    while true do
        if not isDead and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if root then
                -- Quét tất cả các Model có chứa chữ "tree" trong tên (không phân biệt hoa thường)
                currentTreeList = {}
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") then
                        -- Chuyển tên về chữ thường rồi tìm chữ "tree"
                        if string.find(string.lower(obj.Name), "tree") then
                            table.insert(currentTreeList, obj)
                        end
                    end
                end

                -- Thực hiện Teleport theo danh sách đã quét được
                if #currentTreeList > 0 then
                    for i = 1, #currentTreeList do
                        -- Nếu chết trong lúc đang chạy danh sách thì dừng ngay
                        if isDead then break end 

                        local target = currentTreeList[i]
                        if target and target.Parent then
                            -- Dùng pcall để tránh lỗi nếu Model bị xóa đột ngột
                            pcall(function()
                                root.CFrame = target:GetPivot()
                            end)
                            task.wait(0.06) -- Nhảy cây tiếp theo sau 0.1s
                        end
                    end
                end
            end
        end
        task.wait(0.5) -- Đợi một chút trước khi quét danh sách mới để tránh lag máy
    end
end)

end)

