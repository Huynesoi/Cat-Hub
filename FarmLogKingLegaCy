task.spawn(function()
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
-- fix cs1d
local isDead = false
local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

-- Cấu hình hệ thống chống "cây chết"
local treeTracker = {}    -- Đếm số lần tele tới từng cây
local blacklistedTrees = {} -- Danh sách các cây bị bỏ qua vĩnh viễn
local MAX_ATTEMPTS = 20    -- Giới hạn 5 lần tele
local TELEPORT_DELAY = 0.06

-- 1. Luồng Spam Skill E
task.spawn(function()
    local argsE = {
        "DF_BrachioBrachio_E",
        {
            MouseHit = CFrame.new(2121.0048828125, 51.182037353515625, 561.7747802734375, 1, 0, 0, 0, 1, 0, 0, 0, 1),
            Type = "Down"
        }
    }
    while true do
        if not isDead then
            pcall(function() skillRemote:InvokeServer(unpack(argsE)) end)
        end
        task.wait() 
    end
end)

-- 2. Xử lý hồi sinh & dùng Skill V
local function onCharacterAdded(character)
    isDead = true
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function() isDead = true end)

    task.wait(5)
    
    local argsV = {
        "DF_BrachioBrachio_V",
        {
            MouseHit = CFrame.new(2210.47216796875, 32.324493408203125, 874.5543212890625, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        }
    }
    pcall(function() skillRemote:InvokeServer(unpack(argsV)) end)
    isDead = false
end

if LocalPlayer.Character then task.spawn(onCharacterAdded, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

-- 3. Vòng lặp Teleport & Logic lọc cây lỗi
task.spawn(function()
    while true do
        if not isDead and LocalPlayer.Character then
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Lấy danh sách cây mới
                local treesToFarm = {}
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("Model") and string.find(obj.Name:lower(), "tree") then
                        -- CHỈ THÊM VÀO NẾU: Cây chưa bị blacklist
                        if not blacklistedTrees[obj] then
                            table.insert(treesToFarm, obj)
                        end
                    end
                end

                -- Bắt đầu Teleport theo danh sách đã lọc
                if #treesToFarm > 0 then
                    for _, tree in ipairs(treesToFarm) do
                        if isDead then break end
                        
                        -- Kiểm tra lần cuối trước khi nhảy: Cây còn tồn tại không?
                        if tree and tree.Parent then
                            -- Ghi nhận số lần nhảy tới cây này
                            treeTracker[tree] = (treeTracker[tree] or 0) + 1
                            
                            -- Nếu đã quá 5 lần mà cây vẫn còn đó -> Cho vào Blacklist
                            if treeTracker[tree] > MAX_ATTEMPTS then
                                blacklistedTrees[tree] = true
                                treeTracker[tree] = nil -- Giải phóng bộ nhớ đếm
                                continue -- Bỏ qua cây này ngay lập tức
                            end

                            -- Thực hiện nhảy
                            pcall(function()
                                root.CFrame = tree:GetPivot()
                            end)
                            task.wait(TELEPORT_DELAY)
                        else
                            -- Nếu cây đã biến mất (đã farm xong), xóa nó khỏi bộ đếm để sạch bộ nhớ
                            treeTracker[tree] = nil
                        end
                    end
                end
                table.clear(treesToFarm)
            end
        end
        task.wait(0.5) -- Nghỉ 0.5s để server cập nhật cây mới
    end
end)


end)

