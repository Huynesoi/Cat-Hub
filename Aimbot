local function BuildColorRow(parent, yPos, labelText, targetKey)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Position = UDim2.new(0, 0, 0, yPos)
    lbl.Text = labelText
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    
    local gridFrame = Instance.new("Frame", parent)
    gridFrame.Size = UDim2.new(1, -20, 0, 45)
    gridFrame.Position = UDim2.new(0, 10, 0, yPos + 20)
    gridFrame.BackgroundTransparency = 1
    
    local grid = Instance.new("UIGridLayout", gridFrame)
    grid.CellSize = UDim2.new(0, 25, 0, 25)
    grid.CellPadding = UDim2.new(0, 10, 0, 10)
    grid.FillDirection = Enum.FillDirection.Horizontal
    
