-- === LOGIC QUÉT VÀ SMART LOCK TÍCH HỢP ===
local function GetPredictedPosition(targetPart, Camera)
    local pos = targetPart.Position
    if Config.Prediction then
        local velocity = targetPart.AssemblyLinearVelocity or targetPart.Velocity
        if velocity.Magnitude > 150 then velocity = velocity.Unit * 150 end
        local distance = (pos - Camera.CFrame.Position).Magnitude
        local travelTime = math.min(distance / Config.BulletSpeed, 1.5)
        return pos + (velocity * travelTime)
    end
    return pos
end

local function GetClosestTarget(rainbowColor)
    if not IsLocalPlayerAlive() then return nil end

    local Camera = Workspace.CurrentCamera
    if not Camera then return nil end

    local bestTargetFOV = nil
    local bestTargetNormal = nil
    
    local shortestDistFOV = Config.FOVRadius 
    local shortestDistNormal = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    local isCurrentLockStillValid = false

    local function CheckEntity(char, isPlayer)
        local hum = char:FindFirstChildOfClass("Humanoid")
        local part = char:FindFirstChild(Config.TargetPart) or char:FindFirstChild("HumanoidRootPart")

        if hum and part then
            local isDead = hum.Health <= 0
            
            if isDead then
                local hl = char:FindFirstChild("GunnerESP")
                if hl then hl.Enabled = false end
                local detailGui = char:FindFirstChild("GunnerDetails")
                if detailGui then detailGui.Enabled = false end
                if Config.IgnoreDead then return end 
            end

            local isEnemy = true
            if isPlayer then
                local player = Players:GetPlayerFromCharacter(char)
                if Config.TeamCheck and player and player.Team == LocalPlayer.Team then isEnemy = false end
            end

            if Config.ShowESPDetails and isEnemy and (Config.Aimbot or Config.FOVMode or Config.ESP) then
                hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
            else
                hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer
            end

            local hl = char:FindFirstChild("GunnerESP")
            if not hl then
                hl = Instance.new("Highlight")
                hl.Name = "GunnerESP"
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent = char
            end
            
            hl.Enabled = (Config.Aimbot or Config.FOVMode or Config.ESP) and isEnemy
            
            if hl.Enabled then
                if isPlayer then
                    hl.FillColor = ConfigColors.ESPPlayer.isRainbow and rainbowColor or ConfigColors.ESPPlayer.color
                else
                    hl.FillColor = ConfigColors.ESPNPC.isRainbow and rainbowColor or ConfigColors.ESPNPC.color
                end
            end

            local detailGui = char:FindFirstChild("GunnerDetails")
            if not detailGui then
                detailGui = Instance.new("BillboardGui")
                detailGui.Name = "GunnerDetails"
                detailGui.Size = UDim2.new(5, 0, 1.5, 0) 
                detailGui.StudsOffset = Vector3.new(0, 3.5, 0)
                detailGui.AlwaysOnTop = true
                detailGui.Parent = char

                local txtInfo = Instance.new("TextLabel", detailGui)
                txtInfo.Name = "InfoText"
                txtInfo.Size = UDim2.new(1, 0, 0.5, 0)
                txtInfo.BackgroundTransparency = 1
                txtInfo.Font = Enum.Font.GothamBold
                txtInfo.TextScaled = true 
                
                local txtStroke = Instance.new("UIStroke", txtInfo)
                txtStroke.Thickness = 1.2
                txtStroke.Color = Color3.new(0,0,0)

                local bgHealth = Instance.new("Frame", detailGui)
                bgHealth.Name = "BGHealth"
                bgHealth.Size = UDim2.new(0.9, 0, 0.3, 0)
                bgHealth.Position = UDim2.new(0.05, 0, 0.6, 0)
                bgHealth.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
                
                local hpStroke = Instance.new("UIStroke", bgHealth)
                hpStroke.Name = "BorderStroke"
                hpStroke.Thickness = 1.5

                local healthBar = Instance.new("Frame", bgHealth)
                healthBar.Name = "HealthBar"
                healthBar.Size = UDim2.new(1, 0, 1, 0)
                healthBar.BorderSizePixel = 0
            end

            if hl.Enabled and Config.ShowESPDetails then
                detailGui.Enabled = true
                local dist = math.floor((part.Position - Camera.CFrame.Position).Magnitude)
                local velocity = part.AssemblyLinearVelocity or part.Velocity
                local speed = math.floor(velocity.Magnitude)
                detailGui.InfoText.Text = string.format("%d Studs | %d Spd", dist, speed)
                detailGui.InfoText.TextColor3 = ConfigColors.InfoText.isRainbow and rainbowColor or ConfigColors.InfoText.color
                detailGui.BGHealth.BorderStroke.Color = ConfigColors.HealthBorder.isRainbow and rainbowColor or ConfigColors.HealthBorder.color
                local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                detailGui.BGHealth.HealthBar.Size = UDim2.new(hpPercent, 0, 1, 0)
                detailGui.BGHealth.HealthBar.BackgroundColor3 = Color3.new(1 - hpPercent, hpPercent + 0.2, 0.1) 
            else
                detailGui.Enabled = false
            end

            if not isEnemy then return end
            if isPlayer then
                if not Config.AimPlayer then return end
                local player = Players:GetPlayerFromCharacter(char)
                if Config.TargetPlayerName ~= "" and not string.find(string.lower(player.Name), string.lower(Config.TargetPlayerName)) then return end
            end
            if Config.HealthTarget and hum.Health > 30 then return end

            local dist3D = (part.Position - Camera.CFrame.Position).Magnitude
            if dist3D < Config.MinDistance or dist3D > Config.MaxDistance then return end

            -- WALL CHECK: Nếu bị tường cản thì bỏ qua ngay (Kể cả đứa đó đang bị khoá aim)
            if Config.WallCheck then
                local rayParams = RaycastParams.new()
                local ignoreList = {char, RangeDisc}
                if LocalPlayer.Character then table.insert(ignoreList, LocalPlayer.Character) end
                rayParams.FilterDescendantsInstances = ignoreList
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                if Workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * dist3D, rayParams) then return end
            end

            if Config.FOVMode then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if dist2D <= Config.FOVRadius then
                        
                        -- Xác nhận mục tiêu đang bị khoá vẫn nằm trong FOV và chưa chết/chưa nấp tường
                        if Config.LockTarget and CurrentLock == part then
                            isCurrentLockStillValid = true
                        end

                        if dist2D < shortestDistFOV then
                            shortestDistFOV = dist2D
                            bestTargetFOV = part
                        end
                    end
                end
            elseif Config.Aimbot then
                if Config.LockTarget and CurrentLock == part then
                    isCurrentLockStillValid = true
                end

                if dist3D < shortestDistNormal then
                    shortestDistNormal = dist3D
                    bestTargetNormal = part
                end
            end
        end
    end

    for _, p in pairs(Players:GetPlayers()) do 
        if p ~= LocalPlayer and p.Character then CheckEntity(p.Character, true) end 
    end
    if Config.AimNPC then
        for model, _ in pairs(CachedNPCs) do
            if model and model.Parent then CheckEntity(model, false) else CachedNPCs[model] = nil end
        end
    end

    -- XỬ LÝ KẾT QUẢ CUỐI CÙNG
    local finalTarget = nil
    if Config.FOVMode then
        if Config.LockTarget and isCurrentLockStillValid then
            finalTarget = CurrentLock -- Ưu tiên giữ nguyên mục tiêu đang ghim
        else
            finalTarget = bestTargetFOV -- Nếu mục tiêu cũ mất hút hoặc tắt ghim, chọn thằng gần nhất
        end
    elseif Config.Aimbot then
        if Config.LockTarget and isCurrentLockStillValid then
            finalTarget = CurrentLock
        else
            finalTarget = bestTargetNormal
        end
    end

    -- Cập nhật lại biến khoá
    if Config.LockTarget then
        CurrentLock = finalTarget
    else
        CurrentLock = nil
    end

    return finalTarget
end

-- === VÒNG LẶP RENDER CHÍNH ===
RunService:BindToRenderStep("GunnerAimbot", Enum.RenderPriority.Camera.Value + 1, function()
    pcall(function()
        local hue = tick() % 4 / 4
        local rainbowColor = Color3.fromHSV(hue, 1, 1)

        MainStroke.Color = ConfigColors.Menu.isRainbow and rainbowColor or ConfigColors.Menu.color
        FOVStroke.Color = ConfigColors.FOV.isRainbow and rainbowColor or ConfigColors.FOV.color

        local isAlive = IsLocalPlayerAlive()
        local char = isAlive and LocalPlayer.Character or nil
        local hrp = char and char:FindFirstChild("HumanoidRootPart") or nil
        local hum = char and char:FindFirstChildOfClass("Humanoid") or nil

        if Config.ShowRange and hrp then
            if RangeDisc.Parent ~= Workspace then RangeDisc.Parent = Workspace end
            RangeDisc.Color = ConfigColors.Range.isRainbow and rainbowColor or ConfigColors.Range.color
            RangeDisc.Size = Vector3.new(Config.MaxDistance * 2, 1, Config.MaxDistance * 2)
            RangeDisc.CFrame = CFrame.new(hrp.Position - Vector3.new(0, 3, 0))
        else
            if RangeDisc.Parent ~= nil then RangeDisc.Parent = nil end
        end

        if not isAlive then 
            if IsCurrentlyAiming and hum then hum.AutoRotate = true end
            IsCurrentlyAiming = false
            CurrentLock = nil
            return 
        end

        local Camera = Workspace.CurrentCamera
        if not Camera then return end

        if Config.Aimbot or Config.FOVMode then
            local target = GetClosestTarget(rainbowColor)
            
            if target then
                -- Bắt đầu Aim: Tắt AutoRotate
                if not IsCurrentlyAiming then
                    IsCurrentlyAiming = true
                    if hum then hum.AutoRotate = false end
                end

                local finalPos = GetPredictedPosition(target, Camera)
                local currentCameraPos = Camera.CFrame.Position
                
                if typeof(finalPos) == "Vector3" and (finalPos - currentCameraPos).Magnitude > 0.5 then
                    Camera.CFrame = CFrame.lookAt(currentCameraPos, finalPos)
                    
                    local rootPart = char.PrimaryPart or hrp
                    if rootPart then
                        local _, camRotY, _ = Camera.CFrame:ToOrientation()
                        rootPart.CFrame = CFrame.new(rootPart.Position) * CFrame.fromOrientation(0, camRotY, 0)
                    end
                end
            else
                -- Mất mục tiêu: Bật lại AutoRotate
                if IsCurrentlyAiming then
                    IsCurrentlyAiming = false
                    if hum then hum.AutoRotate = true end
                end
            end
        else
            if IsCurrentlyAiming then
                IsCurrentlyAiming = false
                if hum then hum.AutoRotate = true end
            end
            if Config.ESP then GetClosestTarget(rainbowColor) end
        end
    end)
end)
