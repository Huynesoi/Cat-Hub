-- === LOGIC QUÉT VÀ PREDICTION CHÍNH ===
local function GetPredictedPosition(targetPart, Camera)
    local pos = targetPart.Position
    if Config.Prediction then
        local velocity = targetPart.AssemblyLinearVelocity or targetPart.Velocity
        if velocity.Magnitude > 150 then velocity = velocity.Unit * 150 end
        local distance = (pos - Camera.CFrame.Position).Magnitude
        local travelTime = math.min(distance / Config.BulletSpeed, 1.5)
        return pos + (velocity * travelTime)
    end
    return pos
end

local function GetClosestTarget()
    if not IsLocalPlayerAlive() then return nil end

    local Camera = Workspace.CurrentCamera
    if not Camera then return nil end

    local bestTargetFOV = nil
    local bestTargetNormal = nil
    local validSticky = nil
    
    local shortestDistFOV = math.huge
    local shortestDistNormal = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    local function CheckEntity(char, isPlayer)
        local hum = char:FindFirstChildOfClass("Humanoid")
        local part = char:FindFirstChild(Config.TargetPart) or char:FindFirstChild("HumanoidRootPart")

        if hum and part then
            if Config.IgnoreDead and hum.Health <= 0 then return end

            local hl = char:FindFirstChild("GunnerESP")
            if not hl then
                hl = Instance.new("Highlight")
                hl.Name = "GunnerESP"
                hl.FillColor = Color3.new(1, 0, 0)
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                hl.Parent = char
            end

            local isEnemy = true
            if isPlayer then
                local player = Players:GetPlayerFromCharacter(char)
                if Config.TeamCheck and player and player.Team == LocalPlayer.Team then isEnemy = false end
            end

            hl.Enabled = (Config.Aimbot or Config.FOVMode or Config.ESP) and isEnemy

            if not isEnemy then return end
            if isPlayer then
                if not Config.AimPlayer then return end
                local player = Players:GetPlayerFromCharacter(char)
                if Config.TargetPlayerName ~= "" and not string.find(string.lower(player.Name), string.lower(Config.TargetPlayerName)) then return end
            end
            if Config.HealthTarget and hum.Health > 30 then return end

            local dist3D = (part.Position - Camera.CFrame.Position).Magnitude
            if dist3D < Config.MinDistance or dist3D > Config.MaxDistance then return end

            if Config.WallCheck then
                local rayParams = RaycastParams.new()
                local ignoreList = {char, RangeDisc}
                if LocalPlayer.Character then table.insert(ignoreList, LocalPlayer.Character) end
                rayParams.FilterDescendantsInstances = ignoreList
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                if Workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * dist3D, rayParams) then return end
            end

            if Config.AntiOffAim and part == StickyTarget then
                validSticky = part
            end

            if Config.FOVMode then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if dist2D <= Config.FOVRadius and dist2D < shortestDistFOV then
                        shortestDistFOV = dist2D
                        bestTargetFOV = part
                    end
                end
            elseif Config.Aimbot then
                if dist3D < shortestDistNormal then
                    shortestDistNormal = dist3D
                    bestTargetNormal = part
                end
            end
        end
    end

    for _, p in pairs(Players:GetPlayers()) do 
        if p ~= LocalPlayer and p.Character then CheckEntity(p.Character, true) end 
    end
    if Config.AimNPC then
        for model, _ in pairs(CachedNPCs) do
            if model and model.Parent then CheckEntity(model, false) else CachedNPCs[model] = nil end
        end
    end

    local finalTarget = nil
    
    if Config.FOVMode then
        if bestTargetFOV then
            finalTarget = bestTargetFOV
            StickyTarget = bestTargetFOV
        elseif Config.AntiOffAim and validSticky then
            finalTarget = validSticky
        else
            StickyTarget = nil
        end
    elseif Config.Aimbot then
        finalTarget = bestTargetNormal
    end

    if Config.LockTarget then
        if CurrentLock and CurrentLock.Parent then
            local hum = CurrentLock.Parent:FindFirstChildOfClass("Humanoid")
            if Config.IgnoreDead and hum and hum.Health <= 0 then CurrentLock = nil end
            if hum and hum.Health > 0 then return CurrentLock else CurrentLock = nil end
        end
        if finalTarget then CurrentLock = finalTarget end
    end

    return finalTarget
end

-- === VÒNG LẶP RENDER CAMERA & RANGE DISC (FIX) ===
RunService:BindToRenderStep("GunnerAimbot", Enum.RenderPriority.Camera.Value + 1, function()
    pcall(function()
        local isAlive = IsLocalPlayerAlive()
        local hrp = isAlive and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or nil

        -- HIỂN THỊ ĐĨA PHẠM VI (RANGE DISC) CẮM DƯỚI CHÂN
        if Config.ShowRange and hrp then
            if RangeDisc.Parent ~= Workspace then RangeDisc.Parent = Workspace end
            -- X, Z là bán kính, Y là độ dày (1 stud)
            RangeDisc.Size = Vector3.new(Config.MaxDistance * 2, 1, Config.MaxDistance * 2)
            -- Đặt vị trí thụt xuống 3 stud so với RootPart để chạm đất
            RangeDisc.CFrame = CFrame.new(hrp.Position - Vector3.new(0, 3, 0))
        else
            if RangeDisc.Parent ~= nil then RangeDisc.Parent = nil end
        end

        if not isAlive then 
            CurrentLock = nil
            StickyTarget = nil
            return 
        end

        local Camera = Workspace.CurrentCamera
        if not Camera then return end

        if Config.Aimbot or Config.FOVMode then
            local target = GetClosestTarget()
            
            if target then
                local finalPos = GetPredictedPosition(target, Camera)
                local currentCameraPos = Camera.CFrame.Position
                
                if typeof(finalPos) == "Vector3" and (finalPos - currentCameraPos).Magnitude > 0.5 then
                    Camera.CFrame = CFrame.lookAt(currentCameraPos, finalPos)
                    
                    if hrp then
                        local flatTargetPos = Vector3.new(finalPos.X, hrp.Position.Y, finalPos.Z)
                        hrp.CFrame = CFrame.lookAt(hrp.Position, flatTargetPos)
                    end
                end
            end
        else
            if Config.ESP then GetClosestTarget() end
            CurrentLock = nil 
            StickyTarget = nil
        end
    end)
end)
