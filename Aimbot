local function UpdateUIModes()
    for _, item in ipairs(UiElements) do
        if EditMode then
            item.Instance.Visible = true
            if item.Overlay then item.Overlay.Visible = true end
            if item.IsHidden then
                item.Instance.BackgroundColor3 = Color3.fromRGB(200, 170, 0)
            else
                item.RestoreColor()
            end
        else
            if item.Overlay then item.Overlay.Visible = false end
            if item.IsHidden then
                item.Instance.Visible = false
            else
                item.Instance.Visible = true
                item.RestoreColor()
            end
        end
    end
end

