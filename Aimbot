local function IsLocalPlayerAlive()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end

local function CacheEntity(obj)
    if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") then
        local model = obj.Parent
        if model ~= LocalPlayer.Character and not Players:GetPlayerFromCharacter(model) then
            CachedNPCs[model] = true
        end
    end
end

for _, obj in pairs(Workspace:GetDescendants()) do CacheEntity(obj) end
Workspace.DescendantAdded:Connect(CacheEntity)
Workspace.DescendantRemoving:Connect(function(obj)
    if obj:IsA("Model") and CachedNPCs[obj] then CachedNPCs[obj] = nil
    elseif obj:IsA("Humanoid") and obj.Parent and CachedNPCs[obj.Parent] then CachedNPCs[obj.Parent] = nil end
end)

