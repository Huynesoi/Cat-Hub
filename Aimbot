local function CreateButton(text, toggleKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.Parent = ScrollFrame
    Instance.new("UICorner", btn)

    local itemData = {
        Instance = btn,
        IsHidden = false,
        RestoreColor = function()
            btn.BackgroundColor3 = Config[toggleKey] and Color3.fromRGB(0, 130, 0) or Color3.fromRGB(45, 45, 45)
            btn.TextColor3 = Config[toggleKey] and Color3.new(1, 1, 1) or Color3.new(0.8, 0.8, 0.8)
            btn.Text = text .. (Config[toggleKey] and ": ON" or ": OFF")
        end
    }
    table.insert(UiElements, itemData)
    itemData.RestoreColor()

    btn.MouseButton1Click:Connect(function()
        if EditMode then
            itemData.IsHidden = not itemData.IsHidden
            UpdateUIModes()
        else
            Config[toggleKey] = not Config[toggleKey]
            itemData.RestoreColor()
            
            if toggleKey == "FOVMode" then FOVCircle.Visible = Config.FOVMode end
            if toggleKey == "LockTarget" and not Config.LockTarget then CurrentLock = nil end
            if toggleKey == "AntiOffAim" and not Config.AntiOffAim then StickyTarget = nil end
        end
    end)
end

