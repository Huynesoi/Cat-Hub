local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Cấu hình vùng Farm
local farmCenter = CFrame.new(20072.9121, 15684.1641, 20049.5469)
local farmSize = Vector3.new(1500, 10000, 1500)
local halfFarmSize = farmSize / 2

-- Tọa độ Teleport khi mất GUI
local dungeonEntranceCF = CFrame.new(10963.3008, 133.835129, 1250.31189, 1, 0, 0, 0, 1, 0, 0, 0, 1)

local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")
local autoRunning = false
local currentTargetCFrame = nil 

-- Biến hỗ trợ Anti-Stuck
local stuckTimer = 0
local isAntiStuckMode = false
local currentAntiStuckTarget = nil
local noNpcTimer = 0

-- ==========================================
-- [ PHẦN 1: GHIM VỊ TRÍ (FARM & SẢNH CHỜ) ]
-- ==========================================
RunService.Heartbeat:Connect(function()
    if not autoRunning or not humanoidRootPart then return end
    
    local playerGui = player:FindFirstChild("PlayerGui")
    local dungeonUI = playerGui and playerGui:FindFirstChild("DungeonUI")
    
    if not dungeonUI then
        -- KHI KHÔNG CÓ DungeonUI: Ghim tại sảnh chờ
        humanoidRootPart.CFrame = dungeonEntranceCF
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    elseif currentTargetCFrame then
        -- KHI CÓ DungeonUI & ĐANG FARM: Ghim tại vị trí NPC
        humanoidRootPart.CFrame = currentTargetCFrame
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    end
end)

-- ==========================================
-- [ PHẦN 2: SCEPTERS OF FLAME ]
-- ==========================================
local function startScepterLoop()
    _G.Loop = true 
    while _G.Loop and autoRunning and task.wait() do 
        local scepCF = CFrame.new(19792.27734375, 14972.65625, 20029.33203125, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        pcall(function()
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Down" }) 
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Up" }) 
        end)
    end
end

-- ==========================================
-- [ PHẦN 3: KILL AURA ]
-- ==========================================
local function killAuraLoop()
    getgenv().G = true
    getgenv().Creator = 'https://discord.gg/B3HqPPzFYr - HalloweenGaster'
    while getgenv().G and getgenv().Creator == 'https://discord.gg/B3HqPPzFYr - HalloweenGaster' and autoRunning do
        task.wait(0.5)
        pcall(function()
            sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", 200)
            sethiddenproperty(game.Players.LocalPlayer, "MaxSimulationRadius", 200)
        end)
        for i,d in pairs(game.Workspace:GetDescendants()) do
            if d.ClassName == 'Humanoid' and d.Parent.Name ~= game.Players.LocalPlayer.Name then
                d.Health = 0
            end
        end
    end
end

-- ==========================================
-- [ PHẦN 4: LOGIC NPC & ANTI-STUCK (FIX THEO Ý BẠN) ]
-- ==========================================
local function getValidNPCs()
    local npcs = {}
    local parts = Workspace:GetPartBoundsInBox(farmCenter, farmSize)
    local checked = {}
    for _, part in ipairs(parts) do
        local model = part:FindFirstAncestorOfClass("Model")
        if model and not checked[model] then
            checked[model] = true
            local root = model:FindFirstChild("HumanoidRootPart")
            local hum = model:FindFirstChild("Humanoid")
            if root and hum and not Players:GetPlayerFromCharacter(model) and model ~= character then
                local diff = root.Position - farmCenter.Position
                if math.abs(diff.X) <= halfFarmSize.X and math.abs(diff.Y) <= halfFarmSize.Y and math.abs(diff.Z) <= halfFarmSize.Z then
                    table.insert(npcs, model)
                end
            end
        end
    end
    return npcs
end

local function autoSkillLoop()
    while autoRunning do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("DungeonUI") then
            local npcs = getValidNPCs()
            
            if #npcs > 0 then
                -- Nếu có NPC thì reset bộ đếm 2s tắt mode
                noNpcTimer = 0 
                
                if isAntiStuckMode then
                    -- [ CHẾ ĐỘ CHỐNG KẸT ]
                    -- Nếu chưa có mục tiêu, hoặc mục tiêu cũ đã bốc hơi khỏi workspace, hoặc mất HRP
                    if not currentAntiStuckTarget or not currentAntiStuckTarget.Parent or not currentAntiStuckTarget:FindFirstChild("HumanoidRootPart") then
                        currentAntiStuckTarget = npcs[1] -- Lấy con NPC đầu tiên làm con dê tế thần
                    end
                    
                    if currentAntiStuckTarget and currentAntiStuckTarget:FindFirstChild("HumanoidRootPart") then
                        local targetCF = currentAntiStuckTarget.HumanoidRootPart.CFrame
                        currentTargetCFrame = targetCF * CFrame.new(0, -15, 0)
                        
                        -- Dùng skill liên tục vào con này
                        pcall(function()
                            skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = targetCF, Mobile = true})
                        end)
                        task.wait(0.5) -- Delay ngắn để xả skill liên tục
                    end
                else
                    -- [ CHẾ ĐỘ GÔM QUÁI BÌNH THƯỜNG ]
                    local sumPos = Vector3.new(0, 0, 0)
                    local count = 0
                    local boss = nil
                    
                    for _, n in ipairs(npcs) do
                        if n.Name == "Heartbreaker Queen [Lv. 5000]" then boss = n end
                        sumPos = sumPos + n.HumanoidRootPart.Position
                        count = count + 1
                    end
                    
                    local averagePos = sumPos / count
                    
                    local isGrouped = true
                    for _, n in ipairs(npcs) do
                        if (n.HumanoidRootPart.Position - averagePos).Magnitude > 5 then
                            isGrouped = false
                            break
                        end
                    end

                    -- Bộ đếm kẹt
                    if not isGrouped and not boss then
                        stuckTimer = stuckTimer + 0.1
                        if stuckTimer >= 30 then 
                            isAntiStuckMode = true 
                            currentAntiStuckTarget = nil -- Chuẩn bị lấy target mới khi vào mode
                        end
                    else
                        stuckTimer = 0
                    end

                    -- Tung skill gom
                    if not isAntiStuckMode then
                        local finalTargetCF = boss and boss.HumanoidRootPart.CFrame or CFrame.new(averagePos)
                        currentTargetCFrame = finalTargetCF * CFrame.new(0, -15, 0)
                        if isGrouped or boss then
                            pcall(function()
                                skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = finalTargetCF, Mobile = true})
                            end)
                            task.wait(0.8)
                        end
                    end
                end
            else
                -- KHÔNG CÒN BẤT KỲ NPC NÀO TRONG VÙNG FARM
                currentTargetCFrame = nil
                stuckTimer = 0
                
                -- Nếu đang bật Anti-Stuck, bắt đầu đếm ngược 2s để tắt
                if isAntiStuckMode then
                    noNpcTimer = noNpcTimer + 0.1
                    if noNpcTimer >= 2 then
                        isAntiStuckMode = false
                        currentAntiStuckTarget = nil
                        noNpcTimer = 0
                    end
                end
            end
        else
            -- Mất UI (Đang ở sảnh chờ)
            currentTargetCFrame = nil
            stuckTimer = 0
            isAntiStuckMode = false
            noNpcTimer = 0
            currentAntiStuckTarget = nil
        end
        task.wait(0.1)
    end
end

-- ==========================================
