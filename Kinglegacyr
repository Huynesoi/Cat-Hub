local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Cấu hình vùng Farm
local farmCenter = CFrame.new(20072.9121, 15684.1641, 20049.5469) -- Tọa độ từ ảnh bạn gửi
local farmSize = Vector3.new(1500, 10000, 1500)
local halfFarmSize = farmSize / 2

local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")
local autoRunning = false
local currentTargetCFrame = nil 

-- ==========================================
-- [ PHẦN 1: CODE CỦA BẠN - VÙNG 10963 ]
-- ==========================================
local hrp = character:WaitForChild("HumanoidRootPart")
local centerPos = Vector3.new(10963.30078125, 133.8351287841797, 1250.3118896484375)
local regionSize = Vector3.new(2048, 2048, 2048)
local teleportInterval = 0.1
local lastTeleport = 0

player.CharacterAdded:Connect(function(newChar)
    character = newChar
    hrp = newChar:WaitForChild("HumanoidRootPart")
    humanoidRootPart = newChar:WaitForChild("HumanoidRootPart")
end)

local function isInRegion(pos)
    local h = regionSize / 2
    return (pos.X >= centerPos.X - h.X and pos.X <= centerPos.X + h.X and 
            pos.Y >= centerPos.Y - h.Y and pos.Y <= centerPos.Y + h.Y and 
            pos.Z >= centerPos.Z - h.Z and pos.Z <= centerPos.Z + h.Z)
end

RunService.Heartbeat:Connect(function()
    if not character or not hrp or not hrp:IsDescendantOf(workspace) then return end
    if isInRegion(hrp.Position) then
        if tick() - lastTeleport >= teleportInterval then
            hrp.CFrame = CFrame.new(centerPos)
            lastTeleport = tick()
        end
    end
end)

-- ==========================================
-- [ PHẦN 2: CODE CỦA BẠN - SCEPTERS ]
-- ==========================================
local function startScepterLoop()
    _G.Loop = true 
    while _G.Loop and autoRunning and task.wait() do 
        local scepCF = CFrame.new(19792.27734375, 14972.65625, 20029.33203125, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Down" }) 
        skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Up" }) 
    end
end

-- ==========================================
-- [ PHẦN 3: LOGIC FARM - FIX LỖI AUTO TELE ]
-- ==========================================
local function getValidNPCs()
    local npcs = {}
    local parts = Workspace:GetPartBoundsInBox(farmCenter, farmSize)
    local checked = {}
    
    for _, part in ipairs(parts) do
        local model = part:FindFirstAncestorOfClass("Model")
        if model and not checked[model] then
            checked[model] = true
            local hum = model:FindFirstChild("Humanoid")
            local root = model:FindFirstChild("HumanoidRootPart")
            
            -- CHỈ LẤY nếu là NPC sống, có máu và không phải người chơi
            if hum and root and hum.Health > 0 and not Players:GetPlayerFromCharacter(model) and model ~= character then
                local diff = root.Position - farmCenter.Position
                if math.abs(diff.X) <= halfFarmSize.X and math.abs(diff.Y) <= halfFarmSize.Y and math.abs(diff.Z) <= halfFarmSize.Z then
                    table.insert(npcs, model)
                end
            end
        end
    end
    return npcs
end

-- Chỉ ghim vị trí khi THỰC SỰ có mục tiêu trong danh sách lọc
RunService.Heartbeat:Connect(function()
    if autoRunning and currentTargetCFrame and humanoidRootPart then
        humanoidRootPart.CFrame = currentTargetCFrame
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    end
end)

local function killAuraLoop()
    getgenv().G = true
    while autoRunning and getgenv().G do
        pcall(function()
            sethiddenproperty(player, "SimulationRadius", 200)
            sethiddenproperty(player, "MaxSimulationRadius", 200)
        end)
        local targets = getValidNPCs()
        for _, npc in ipairs(targets) do
            local hum = npc:FindFirstChild("Humanoid")
            if hum then hum.Health = 0 end
        end
        task.wait(0.5)
    end
end

local function autoSkillLoop()
    while autoRunning do
        local npcs = getValidNPCs()
        
        if #npcs > 0 then
            local target = nil
            for _, n in ipairs(npcs) do 
                if n.Name == "Heartbreaker Queen [Lv. 5000]" then target = n break end 
            end
            target = target or npcs[1]
            
            local targetPos = target.HumanoidRootPart.CFrame
            currentTargetCFrame = targetPos * CFrame.new(0, -15, 0)
            
            skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = targetPos, Mobile = true})
            task.wait(0.8)
        else
            -- NẾU KHÔNG CÓ NPC NÀO CÒN SỐNG: Xóa sạch ghim, đứng yên
            currentTargetCFrame = nil
        end
        task.wait(0.5)
    end
end

