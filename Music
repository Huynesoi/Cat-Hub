    end
end)
toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if inputStartPos then
            local moveDistance = (input.Position - inputStartPos).Magnitude
            if moveDistance < dragThreshold and (os.clock() - inputStartTime) < 0.5 then
                mainFrame.Visible = not mainFrame.Visible
            end
        end
    end
end)

-- LOGIC KÉO NÚT TRÒN ĐỂ TUA NHẠC (SLIDER MỞ RỘNG)
local function updateSliderPosition(inputPosition)
    if currentSound.TimeLength > 0 then
        local barAbsolutePosition = progressBg.AbsolutePosition
        local barAbsoluteSize = progressBg.AbsoluteSize
        local relativeX = inputPosition.X - barAbsolutePosition.X
        local percentage = math.clamp(relativeX / barAbsoluteSize.X, 0, 1)
        
        progressBar.Size = UDim2.new(percentage, 0, 1, 0)
        sliderDot.Position = UDim2.new(1, -7, 0.5, -7)
        timeLabel.Text = formatTime(percentage * currentSound.TimeLength) .. " / " .. formatTime(currentSound.TimeLength)
        return percentage
    end
    return 0
end

sliderDot.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        isDraggingSlider = true
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDraggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSliderPosition(input.Position)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if isDraggingSlider and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        isDraggingSlider = false
        if currentSound.TimeLength > 0 then
            local mousePos = UserInputService:GetMouseLocation()
            local finalPercentage = updateSliderPosition(Vector2.new(mousePos.X, mousePos.Y - 36))
            currentSound.TimePosition = finalPercentage * currentSound.TimeLength
        end
    end
end)

local function getFileName(url, idx)
    local hash = string.sub(url, -12):gsub("[^%w]", "")
    return "HTrack_" .. idx .. "_" .. hash .. ".mp3"
end

-- LOGIC AUTO CUỘN CHỮ THÔNG MINH KHI TÊN BÀI HÁT QUÁ DÀI
local currentScrollTween = nil
local function updateTrackName(text)
    -- Dừng và xóa hiệu ứng cuộn cũ nếu đang chạy
    if currentScrollTween then currentScrollTween:Cancel() currentScrollTween = nil end
    
    trackNameLabel.Text = text
    trackNameLabel.Position = UDim2.new(0, 0, 0, 0)
    trackNameLabel.Size = UDim2.new(1, 0, 1, 0)
    trackNameLabel.TextXAlignment = Enum.TextXAlignment.Center
    
    -- Đợi UI render xong kích thước thực tế của chữ
    task.wait(0.1)
    
    local textWidth = trackNameLabel.TextBounds.X
    local frameWidth = trackFrame.AbsoluteSize.X
    
    -- Nếu chiều dài chữ lớn hơn khung hiển thị (300px) thì kích hoạt cuộn
    if textWidth > frameWidth then
        trackNameLabel.TextXAlignment = Enum.TextXAlignment.Left
        trackNameLabel.Size = UDim2.new(0, textWidth, 1, 0)
        
        task.spawn(function()
            local currentText = trackNameLabel.Text
            while trackNameLabel.Text == currentText do
                task.wait(2) -- Đợi 2s ở vị trí ban đầu trước khi cuộn
                if trackNameLabel.Text ~= currentText then break end
                
                -- Tạo tween dịch chuyển chữ sang trái
                local targetX = -(textWidth - frameWidth + 10)
                local duration = math.max((textWidth / 30), 3) -- Tốc độ cuộn mượt mà tùy độ dài chữ
                
                currentScrollTween = TweenService:Create(trackNameLabel, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                    Position = UDim2.new(0, targetX, 0, 0)
                })
                currentScrollTween:Play()
                currentScrollTween.Completed:Wait()
                
                task.wait(2) -- Cuộn hết chữ, đợi 2s ở điểm cuối
                if trackNameLabel.Text ~= currentText then break end
                
                -- Reset về vị trí ban đầu
                trackNameLabel.Position = UDim2.new(0, 0, 0, 0)
            end
        end)
    end
end

-- LOGIC PHÁT NHẠC
local function playTrack(idx)
    if idx < 1 or idx > #trackList then return end
    currentIndex = idx
    saveIndex(currentIndex)
    
    local track = trackList[idx]
    local trackName = (track.Name and track.Name ~= "") and track.Name or "Bài số " .. idx
    
    if not track.Url or track.Url == "" then 
        updateTrackName("⚠️ [Trống] " .. trackName)
        timeLabel.Text = "00:00 / 00:00"
        progressBar.Size = UDim2.new(0, 0, 1, 0)
        sliderDot.Position = UDim2.new(0, -7, 0.5, -7)
        isPlaying = false
        currentSound:Stop()
        playBtn.Text = "▶"
        return 
    end
    
    updateTrackName("⏳ Đang tải: " .. trackName)
    local fname = getFileName(track.Url, idx)
    
    task.spawn(function()
        if isfile and isfile(fname) then
            currentSound.SoundId = getcustomasset(fname)
            updateTrackName("🔊 " .. trackName)
            playBtn.Text = "⏸"
            isPlaying = true
            currentSound:Play()
            muteGameSounds()
            return
        end
        
        if not requestFunction then
            updateTrackName("❌ Executor thiếu hàm Request!")
            return
        end
        
        local success, res = pcall(function()
            return requestFunction({Url = track.Url, Method = "GET"})
        end)
        
        if success and res and res.StatusCode == 200 then
            if writefile then writefile(fname, res.Body) end
            currentSound.SoundId = getcustomasset(fname)
            updateTrackName("🔊 " .. trackName)
            playBtn.Text = "⏸"
            isPlaying = true
            currentSound:Play()
            muteGameSounds()
        else
            updateTrackName("❌ Lỗi tải file: " .. trackName)
        end
    end)
end

playBtn.MouseButton1Click:Connect(function()
    if isPlaying then
        isPlaying = false currentSound:Pause() unmuteGameSounds() playBtn.Text = "▶"
    else
        if currentSound.SoundId ~= "" then
            isPlaying = true currentSound:Resume() muteGameSounds() playBtn.Text = "⏸"
        else
            playTrack(currentIndex)
        end
    end
end)

