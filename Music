local function muteGameSounds()
    for _, sound in ipairs(game:GetDescendants()) do
        if sound:IsA("Sound") and sound ~= currentSound then
            if not originalVolumes[sound] then originalVolumes[sound] = sound.Volume end
            sound.Volume = 0
        end
    end
end

local function unmuteGameSounds()
    for sound, vol in pairs(originalVolumes) do if sound and sound.Parent then sound.Volume = vol end end
    table.clear(originalVolumes)
end

