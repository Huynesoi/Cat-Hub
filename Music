-- ĐỒNG BỘ SLIDER THEO THỜI GIAN THỰC + ĐỔI BÀI KHI HẾT NHẠC
task.spawn(function()
    while true do
        task.wait(0.1)
        if currentSound.SoundId ~= "" and currentSound.TimeLength > 0 then
            local pos = currentSound.TimePosition
            local length = currentSound.TimeLength
            
            if isPlaying and not isDraggingSlider then
                progressBar.Size = UDim2.new(pos / length, 0, 1, 0)
                sliderDot.Position = UDim2.new(1, -7, 0.5, -7)
                timeLabel.Text = formatTime(pos) .. " / " .. formatTime(length)
            end
            
            if pos >= length - 0.5 and not isDraggingSlider then
                currentSound:Stop()
                -- LOGIC TỰ ĐỘNG CHUYỂN BÀI HOẶC VỀ BÀI 1 KHI HẾT DANH SÁCH
                if currentIndex < #trackList then 
                    playTrack(currentIndex + 1) 
                else 
                    playTrack(1) -- Tự động quay về bài số 1 khi hết list nhạc
                end
                task.wait(1)
            end
        end
    end
end)

