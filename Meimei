-- XỬ LÝ NÚT BẤM
-- ==========================================

BtnTele.MouseButton1Click:Connect(function()
    T_Tele = not T_Tele
    BtnTele.Text = T_Tele and "Auto Tele Y -350: ON" or "Auto Tele Y -350: OFF"
    BtnTele.BackgroundColor3 = T_Tele and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(130, 30, 30)
    if T_Tele then TeleUnder() end
end)

Btn1.MouseButton1Click:Connect(function()
    T1 = not T1
    Btn1.Text = T1 and "Auto Heal 0 HP: ON" or "Auto Heal 0 HP: OFF"
    Btn1.BackgroundColor3 = T1 and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(130, 30, 30)
    task.spawn(function()
        while T1 do
            local charFolder = Workspace:FindFirstChild("Characters")
            if charFolder then
                for _, obj in pairs(charFolder:GetChildren()) do
                    local hum = obj:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health <= 0 then FireHeal(obj) end
                end
            end
            task.wait(0.3)
        end
    end)
end)

Btn2.MouseButton1Click:Connect(function()
    T2 = not T2
    Btn2.Text = T2 and "STOP LOOP" or "START SPAM LOOP"
    Btn2.BackgroundColor3 = T2 and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(130, 30, 30)
    
    task.spawn(function()
        local ResetRemote = ReplicatedStorage:WaitForChild("Knit"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("JoinService"):WaitForChild("RE"):WaitForChild("Reset")
        
        while T2 do
            local target = GetAnyTarget(BoxName.Text)
            local waitTime = tonumber(BoxDelay.Text) or 0.1
            
            if target then
                -- Soi máu mục tiêu
                local targetHum = target:FindFirstChildOfClass("Humanoid")
                if targetHum then CurrentCamera.CameraSubject = targetHum end
                
                -- Thực hiện combo
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Moveset") then
                    if FireHeal(target) then
                        task.wait(waitTime)
                        ResetRemote:FireServer() -- Gọi Remote Reset bạn đưa
                        
                        -- Chờ nhân vật mới xuất hiện
                        LocalPlayer.CharacterAdded:Wait()
                        task.wait(0.3) 
                    end
                end
            end
            task.wait()
        end
        -- Trả camera về mình khi tắt
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            CurrentCamera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        end
    end)
end)
