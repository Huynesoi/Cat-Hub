-- ==========================================
-- LOGIC CORE
-- ==========================================
local T1, T2, T_Tele = false, false, false

local function TeleUnder()
    if T_Tele and LocalPlayer.Character then
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = root.CFrame * CFrame.new(0, -350, 0)
        end
    end
end

-- Tự động Tele mỗi khi hồi sinh (nếu bật)
LocalPlayer.CharacterAdded:Connect(function(char)
    if T_Tele then
        char:WaitForChild("HumanoidRootPart")
        task.wait(0.2)
        TeleUnder()
    end
end)

local function GetAnyTarget(txt)
    if txt == "" then return nil end
    txt = txt:lower()
    local charFolder = Workspace:FindFirstChild("Characters")
    if charFolder then
        for _, obj in pairs(charFolder:GetChildren()) do
            if obj.Name:lower():find(txt) then return obj end
        end
    end
    return nil
end

local function FireHeal(targetInstance)
    local myChar = LocalPlayer.Character
    if targetInstance and myChar then
        local moveset = myChar:FindFirstChild("Moveset")
        local birdControl = moveset and moveset:FindFirstChild("Bird Control")
        if birdControl then
            local args = { birdControl, { false, targetInstance, Vector3.new(0,0,0), Vector3.new(0,0,0) } }
            local remote = ReplicatedStorage:FindFirstChild("Knit") and ReplicatedStorage.Knit.Knit.Services.BirdControlService.RE.Activated
            if remote then 
                remote:FireServer(unpack(args))
                return true
            end
        end
    end
    return false
end

