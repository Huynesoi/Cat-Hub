end)

local targetNames = {"Thief1", "Thief2", "Thief3", "Thief4", "Thief5"}

local function startLogic()
    local hrp = getHRP()
    if not hrp then return end

    -- Bước 1: Kiểm tra xem đã hoàn thành di chuyển chưa
    if not _G.PointsReached then
        -- Tới CFrame 1
        local cf1 = CFrame.new(-497.827911, 23.6579113, -1249.22119, -0.990029454, 6.10989703e-09, -0.140860662, 4.25602842e-09, 1, 1.3462266e-08, 0.140860662, 1.2728532e-08, -0.990029454)
        moveSmooth(cf1, flySpeedPoints)
        
        local s = tick()
        while tick() - s < 2 and _G.AutoFarm do
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") and (hrp.Position - v.Parent.Position).Magnitude < 15 then
                    fireproximityprompt(v)
                end
            end
            task.wait(0.5)
        end

        -- Tới CFrame 2
        local cf2 = CFrame.new(162.013504, 15.9430065, -197.37149, 0.335018128, -1.29370274e-08, 0.942211688, -2.27819168e-08, 1, 2.18309566e-08, -0.942211688, -2.87791551e-08, 0.335018128)
        moveSmooth(cf2, flySpeedPoints)
        
        _G.PointsReached = true -- Đã bay xong, lần sau sẽ không bay lại
    end

    -- Bước 2: Vòng lặp săn NPC (Dù tắt bật cũng sẽ chỉ chạy từ đây)
    while _G.AutoFarm do
        local npcs = workspace:FindFirstChild("NPCs")
        if npcs then
            for _, name in ipairs(targetNames) do
                if not _G.AutoFarm then break end
                local target = npcs:FindFirstChild(name)
                
                if target and target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 then
                    local targetHRP = target:FindFirstChild("HumanoidRootPart")
                    if targetHRP then
                        -- Equip Tool "Combat"
                        pcall(function()
                            local tool = player.Backpack:FindFirstChild("Combat")
                            if tool then player.Character.Humanoid:EquipTool(tool) end
                        end)

                        -- Bay tới NPC (250 stud/s) và đánh cho tới khi chết
                        while _G.AutoFarm and target.Parent and target.Humanoid.Health > 0 do
                            local currentHRP = getHRP()
                            if currentHRP then
                                moveSmooth(targetHRP.CFrame * CFrame.new(0, 0, 3), flySpeedNPC)
                            end
                            task.wait()
                        end
                        _G.KillCount = _G.KillCount + 1
                        KillLabel.Text = "Kills: " .. _G.KillCount
                    end
                end
            end
        end
        task.wait(1) -- Chờ NPC hồi sinh rồi quét tiếp
    end
end

