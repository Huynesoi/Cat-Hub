local CF_URL = "https://control.huynesoi270111.workers.dev"
local req = (syn and syn.request) or (http and http.request) or http_request or request
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local UserInputService = game:GetService("UserInputService")

local MASTERS = {["huynesoi"] = true, ["soicon19911"] = true}
local isMaster = MASTERS[LP.Name] or false

local selectedLead = nil
local selectedFollowers = {}
local currentViewing = nil
local isControlling = false

local function Post(path, data)
    local suc, res = pcall(function()
        return req({
            Url = CF_URL .. path,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    if suc and res and res.Body then
        local s, d = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if s then return d end
    end
    return nil
end

if isMaster then
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 650, 0, 480)
    main.Position = UDim2.new(0.5, -325, 0.5, -240)
    main.BackgroundColor3 = Color3.fromHex("#1E1F22")
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main)

    local leftPanel = Instance.new("Frame", main)
    leftPanel.Size = UDim2.new(0.35, 0, 1, -20)
    leftPanel.Position = UDim2.new(0, 10, 0, 10)
    leftPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", leftPanel)

    local scroll = Instance.new("ScrollingFrame", leftPanel)
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 8)

    local rightPanel = Instance.new("Frame", main)
    rightPanel.Size = UDim2.new(0.65, -30, 1, -20)
    rightPanel.Position = UDim2.new(0.35, 20, 0, 10)
    rightPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", rightPanel)

    local avatarImg = Instance.new("ImageLabel", rightPanel)
    avatarImg.Size = UDim2.new(0, 80, 0, 80)
    avatarImg.Position = UDim2.new(0, 10, 0, 10)
    avatarImg.BackgroundColor3 = Color3.fromHex("#1E1F22")
    Instance.new("UICorner", avatarImg)

    local dInfo = Instance.new("TextLabel", rightPanel)
    dInfo.Size = UDim2.new(1, -110, 0, 80)
    dInfo.Position = UDim2.new(0, 100, 0, 10)
    dInfo.BackgroundTransparency = 1
    dInfo.TextColor3 = Color3.new(1,1,1)
    dInfo.TextXAlignment = Enum.TextXAlignment.Left
    dInfo.RichText = true

    local dJoin = Instance.new("TextButton", rightPanel)
    dJoin.Size = UDim2.new(0.9, 0, 0, 30)
    dJoin.Position = UDim2.new(0.05, 0, 0, 100)
    dJoin.BackgroundColor3 = Color3.fromRGB(60,60,60)
    dJoin.TextColor3 = Color3.new(1,1,1)
    dJoin.Text = "JOIN SERVER"
    local sJoin = Instance.new("UIStroke", dJoin) sJoin.Color = Color3.new(1,1,1)
    Instance.new("UICorner", dJoin)

    local dControl = Instance.new("TextButton", rightPanel)
    dControl.Size = UDim2.new(0.42, 0, 0, 40)
    dControl.Position = UDim2.new(0.05, 0, 0, 140)
    dControl.BackgroundColor3 = Color3.fromRGB(255,255,0)
    dControl.Text = "SELECT LEAD"
    Instance.new("UICorner", dControl)

    local dSync = Instance.new("TextButton", rightPanel)
    dSync.Size = UDim2.new(0.42, 0, 0, 40)
    dSync.Position = UDim2.new(0.53, 0, 0, 140)
    dSync.BackgroundColor3 = Color3.fromRGB(0,255,0)
    dSync.Text = "ADD SLAVE"
    Instance.new("UICorner", dSync)

    local eInput = Instance.new("TextBox", rightPanel)
    eInput.Size = UDim2.new(0.9, 0, 0, 60)
    eInput.Position = UDim2.new(0.05, 0, 0, 190)
    eInput.BackgroundColor3 = Color3.fromHex("#1E1F22")
    eInput.TextColor3 = Color3.new(1,1,1)
    eInput.PlaceholderText = "Paste script here..."
    Instance.new("UICorner", eInput)

    local eRun = Instance.new("TextButton", rightPanel)
    eRun.Size = UDim2.new(0.9, 0, 0, 30)
    eRun.Position = UDim2.new(0.05, 0, 0, 260)
    eRun.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    eRun.Text = "EXECUTE ALL"
    Instance.new("UICorner", eRun)

    local startBtn = Instance.new("TextButton", rightPanel)
    startBtn.Size = UDim2.new(0.9, 0, 0, 40)
    startBtn.Position = UDim2.new(0.05, 0, 0, 300)
    startBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
    startBtn.Text = "START MASTER CONTROL"
    Instance.new("UICorner", startBtn)

    local cancelBtn = Instance.new("TextButton", rightPanel)
    cancelBtn.Size = UDim2.new(0.9, 0, 0, 40)
    cancelBtn.Position = UDim2.new(0.05, 0, 0, 350)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(240, 71, 71)
    cancelBtn.Text = "STOP CONTROL"
    Instance.new("UICorner", cancelBtn)

    local function updateList()
        local users = Post("/list", {})
        if not users then return end
        for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        for _, u in ipairs(users) do
            local b = Instance.new("TextButton", scroll)
            b.Size = UDim2.new(1, 0, 0, 45)
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.TextColor3 = Color3.new(1,1,1)
            b.Text = "      " .. u.name
            b.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", b)
            local s = Instance.new("UIStroke", b) s.Color = Color3.new(1,1,1)
            local icon = Instance.new("ImageLabel", b)
            icon.Size = UDim2.new(0, 35, 0, 35)
            icon.Position = UDim2.new(0, 5, 0.5, -17)
            icon.Image = "rbxthumb://type=AvatarHeadShot&id="..u.id.."&w=150&h=150"
            Instance.new("UICorner", icon).CornerRadius = UDim.new(1,0)

            if selectedLead == u.name then b.BackgroundColor3 = Color3.fromRGB(255, 255, 0) b.TextColor3 = Color3.new(0,0,0)
            elseif selectedFollowers[u.name] then b.BackgroundColor3 = Color3.fromRGB(0, 255, 0) b.TextColor3 = Color3.new(0,0,0) end

            b.MouseButton1Click:Connect(function()
                currentViewing = u
                avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id="..u.id.."&w=420&h=420"
                dInfo.Text = string.format("<b>Name:</b> %s\n<b>ID:</b> %d", u.name, u.id)
            end)
        end
    end

    dJoin.MouseButton1Click:Connect(function() if currentViewing then TeleportService:TeleportToPlaceInstance(currentViewing.placeId, currentViewing.jobId, LP) end end)
    dControl.MouseButton1Click:Connect(function() if currentViewing then selectedLead = currentViewing.name updateList() end end)
    dSync.MouseButton1Click:Connect(function() if currentViewing then selectedFollowers[currentViewing.name] = true updateList() end end)

    startBtn.MouseButton1Click:Connect(function()
        if not selectedLead then return end
        isControlling = true
        
        -- Lấy CFrame Lead 1 lần duy nhất
        local target = Players:FindFirstChild(selectedLead)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            LP.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
        end
        
        -- Mở Backpack & Gui
        game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)

        task.spawn(function()
            while isControlling and task.wait(0.1) do
                local root = LP.Character.HumanoidRootPart
                local cf = root.CFrame
                Post("/send_master_pos", {
                    x = cf.X, y = cf.Y, z = cf.Z, 
                    rx = cf.LookVector.X, ry = cf.LookVector.Y, rz = cf.LookVector.Z,
                    jump = (LP.Character.Humanoid.Jump)
                })
            end
        end)
    end)

    UserInputService.InputBegan:Connect(function(input, gpe)
        if isControlling and not gpe then
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if selectedLead then Post("/send_cmd", {target = selectedLead, type = "click"}) end
                for fName, _ in pairs(selectedFollowers) do Post("/send_cmd", {target = fName, type = "click"}) end
            end
        end
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        isControlling = false
        selectedLead = nil; selectedFollowers = {}; updateList()
    end)

    task.spawn(function() while task.wait(3) do updateList() end end)

else
    -- PHẦN CLONE (SLAVE & LEAD)
    local slaveGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local sBtn = Instance.new("TextButton", slaveGui)
    sBtn.Size = UDim2.new(0, 150, 0, 50)
    sBtn.Position = UDim2.new(0.5, -75, 0, 10)
    sBtn.Text = "ACTIVATE CLONE"
    Instance.new("UICorner", sBtn)

    sBtn.MouseButton1Click:Connect(function()
        slaveGui:Destroy()
        local startT = os.time()
        task.spawn(function()
            while task.wait(3) do Post("/update", {id = LP.UserId, name = LP.Name, jobId = game.JobId, placeId = game.PlaceId, uptime = os.time()-startT}) end
        end)
        
        -- Loop nhận CFrame Master
        task.spawn(function()
            while task.wait() do
                local state = Post("/get_master_pos", {})
                if state and state.x then
                    LP.Character.HumanoidRootPart.CFrame = CFrame.new(state.x, state.y, state.z)
                    if state.jump then LP.Character.Humanoid.Jump = true end
                end
            end
        end)

        -- Loop nhận Lệnh Click/Execute
        task.spawn(function()
            while task.wait(0.5) do
                local cmd = Post("/get_cmd", {name = LP.Name})
                if cmd then
                    if cmd.type == "click" then
                        local tool = LP.Character:FindFirstChildOfClass("Tool")
                        if tool then tool:Activate() end
                    elseif cmd.type == "execute" then
                        local f = loadstring(cmd.data) if f then task.spawn(f) end
                    end
                end
            end
        end)
    end)
end
