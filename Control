local CF_URL = "https://control.huynesoi270111.workers.dev"
local req = (syn and syn.request) or (http and http.request) or request
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

local MASTERS = {["huynesoi"] = true, ["soicon19911"] = true}
local isMaster = MASTERS[LP.Name] or false

local selectedLead = nil
local selectedFollowers = {}

local function Post(path, data)
    local s, r = pcall(function()
        return req({
            Url = CF_URL .. path,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    return s and r.StatusCode == 200 and HttpService:JSONDecode(r.Body) or nil
end

if isMaster then
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 450, 0, 400)
    main.Position = UDim2.new(0.5, -225, 0.5, -200)
    main.BackgroundColor3 = Color3.fromHex("#1E1F22")
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main)

    -- CÁC TRANG (PAGES)
    local listPage = Instance.new("Frame", main)
    listPage.Size = UDim2.new(1, 0, 1, 0)
    listPage.BackgroundTransparency = 1

    local detailPage = Instance.new("Frame", main)
    detailPage.Size = UDim2.new(1, 0, 1, 0)
    detailPage.BackgroundTransparency = 1
    detailPage.Visible = false

    local execPage = Instance.new("Frame", main)
    execPage.Size = UDim2.new(1, 0, 1, 0)
    execPage.BackgroundTransparency = 1
    execPage.Visible = false

    -- GIAO DIỆN LIST PAGE
    local scroll = Instance.new("ScrollingFrame", listPage)
    scroll.Size = UDim2.new(1, -20, 0.7, 0)
    scroll.Position = UDim2.new(0, 10, 0, 50)
    scroll.BackgroundColor3 = Color3.fromHex("#2B2D31")
    scroll.BorderSizePixel = 0
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)

    -- GIAO DIỆN DETAIL PAGE
    local detailInfo = Instance.new("TextLabel", detailPage)
    detailInfo.Size = UDim2.new(1, -40, 0.4, 0)
    detailInfo.Position = UDim2.new(0, 20, 0, 60)
    detailInfo.BackgroundColor3 = Color3.fromHex("#2B2D31")
    detailInfo.TextColor3 = Color3.new(1,1,1)
    detailInfo.TextSize = 14
    detailInfo.TextYAlignment = Enum.TextYAlignment.Top

    -- NÚT CHUYỂN TRANG
    local function showPage(p)
        listPage.Visible = (p == "list")
        detailPage.Visible = (p == "detail")
        execPage.Visible = (p == "exec")
    end

    local function createBtn(txt, pos, size, clr, parent)
        local b = Instance.new("TextButton", parent)
        b.Text = txt; b.Position = pos; b.Size = size
        b.BackgroundColor3 = clr; b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b)
        return b
    end

    local backBtn = createBtn("< BACK", UDim2.new(0, 10, 0, 10), UDim2.new(0, 80, 0, 30), Color3.fromRGB(80,80,80), main)
    backBtn.MouseButton1Click:Connect(function() showPage("list") end)

    local toExecBtn = createBtn("OPEN EXECUTOR", UDim2.new(0.7, 0, 0, 10), UDim2.new(0, 120, 0, 30), Color3.fromRGB(50,150,50), main)
    toExecBtn.MouseButton1Click:Connect(function() showPage("exec") end)

    -- LOGIC LIST & DETAIL
    local function updateList()
        for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        local users = Post("/list", {}) or {}
        for _, u in ipairs(users) do
            local b = createBtn(u.name, UDim2.new(0,0,0,0), UDim2.new(1, 0, 0, 40), Color3.fromRGB(45, 45, 45), scroll)
            
            -- Màu sắc theo ý bạn
            if selectedLead == u.name then b.BackgroundColor3 = Color3.fromRGB(255, 255, 0); b.TextColor3 = Color3.new(0,0,0)
            elseif selectedFollowers[u.name] then b.BackgroundColor3 = Color3.fromRGB(0, 255, 0); b.TextColor3 = Color3.new(0,0,0) end

            b.MouseButton1Click:Connect(function()
                -- Hiện Detail
                showPage("detail")
                detailInfo.Text = string.format("NAME: %s\nID: %d\nGAME: %d\nUPTIME: %ds", u.name, u.id, u.placeId, u.uptime)
                
                -- Nút Control trong Detail
                local controlBtn = createBtn("CONTROL", UDim2.new(0.05, 0, 0.5, 0), UDim2.new(0.4, 0, 0.2, 0), Color3.fromRGB(88, 101, 242), detailPage)
                controlBtn.MouseButton1Click:Connect(function()
                    selectedLead = u.name
                    showPage("exec")
                end)

                local syncBtn = createBtn("SYNC THIS", UDim2.new(0.55, 0, 0.5, 0), UDim2.new(0.4, 0, 0.2, 0), Color3.fromRGB(255, 255, 0), detailPage)
                syncBtn.TextColor3 = Color3.new(0,0,0)
                syncBtn.MouseButton1Click:Connect(function()
                    selectedFollowers[u.name] = true
                    showPage("list")
                    updateList()
                end)
            end)
        end
    end

    -- GIAO DIỆN EXECUTOR PAGE
    local execInput = Instance.new("TextBox", execPage)
    execInput.Size = UDim2.new(1, -20, 0.6, 0)
    execInput.Position = UDim2.new(0, 10, 0.15, 0)
    execInput.BackgroundColor3 = Color3.fromHex("#2B2D31")
    execInput.TextColor3 = Color3.new(1,1,1)
    execInput.TextXAlignment = Enum.TextXAlignment.Left
    execInput.TextYAlignment = Enum.TextYAlignment.Top
    execInput.ClearTextOnFocus = false
    execInput.Text = ""

    local runBtn = createBtn("RUN ON ALL SELECTED", UDim2.new(0.1, 0, 0.8, 0), UDim2.new(0.8, 0, 0.15, 0), Color3.fromRGB(50, 150, 50), execPage)
    runBtn.MouseButton1Click:Connect(function()
        local code = execInput.Text
        if selectedLead then Post("/send_cmd", {target = selectedLead, type = "execute", data = code}) end
        for fName, _ in pairs(selectedFollowers) do Post("/send_cmd", {target = fName, type = "execute", data = code}) end
    end)

    -- Nút đồng bộ chung ở List Page
    local syncEnter = createBtn("SYNC ENTER", UDim2.new(0.1, 0, 0.8, 0), UDim2.new(0.8, 0, 0.1, 0), Color3.fromRGB(88, 101, 242), listPage)
    syncEnter.MouseButton1Click:Connect(function()
        if not selectedLead then return end
        for fName, _ in pairs(selectedFollowers) do
            Post("/send_cmd", {target = fName, type = "sync_to", data = selectedLead})
        end
    end)

    task.spawn(function() while task.wait(5) do if listPage.Visible then updateList() end end end)
    updateList()

else
    -- PHẦN DÀNH CHO CLONE (SLAVE)
    task.spawn(function()
        while task.wait(3) do
            Post("/update", {id = LP.UserId, name = LP.Name, jobId = game.JobId, placeId = game.PlaceId, uptime = os.time()})
        end
    end)

    task.spawn(function()
        local syncingWith = nil
        while task.wait(0.3) do
            local cmd = Post("/get_cmd", {name = LP.Name})
            if cmd then
                if cmd.type == "sync_to" then syncingWith = cmd.data
                elseif cmd.type == "execute" then
                    local f, e = loadstring(cmd.data)
                    if f then task.spawn(f) end
                end
            end
            if syncingWith then
                local t = Players:FindFirstChild(syncingWith)
                if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                    if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                        LP.Character.Humanoid:MoveTo(t.Character.HumanoidRootPart.Position)
                    end
                end
            end
        end
    end)
end
