local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- ==========================================
-- [ CẤU HÌNH TỰ ĐỘNG ]
-- ==========================================
local AutoConfig = {
    AutoOn = true,
    PlayerList = {
        ["huynesoi9999"] = 1,
        ["TenAccPhuSo1"] = 2,
        ["TenAccPhuSo2"] = 3,
        ["TenAccPhuSo3"] = 4
    }
}
-- ==========================================

local farmCenter = CFrame.new(20072.9121, 15684.1641, 20049.5469)
local farmSize = Vector3.new(1500, 10000, 1500)
local halfFarmSize = farmSize / 2
local dungeonEntranceCF = CFrame.new(10963.3008, 133.835129, 1250.31189, 1, 0, 0, 0, 1, 0, 0, 0, 1)

local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

local autoRunning = false
local currentTargetCFrame = nil
local playerIndex = 1
local lockedTarget = nil -- Biến dùng để khóa mục tiêu

-- [ HÀM KIỂM TRA NPC CÒN SỐNG ]
local function isAlive(npc)
    return npc and npc.Parent and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 and npc:FindFirstChild("HumanoidRootPart")
end

task.spawn(function()
    while true do
        if autoRunning and humanoidRootPart then
            local playerGui = player:FindFirstChild("PlayerGui")
            if not (playerGui and playerGui:FindFirstChild("DungeonUI")) then
                humanoidRootPart.CFrame = dungeonEntranceCF
                humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                task.wait(0.1)
            else
                task.wait(0.5)
            end
        else
            task.wait(1)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not autoRunning or not humanoidRootPart then return end
    if currentTargetCFrame then
        humanoidRootPart.CFrame = currentTargetCFrame
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    end
end)

local function startScepterLoop()
    _G.Loop = true 
    while _G.Loop and autoRunning and task.wait(0.2) do 
        local scepCF = CFrame.new(19792.27734375, 14972.65625, 20029.33203125)
        pcall(function()
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Down" }) 
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Up" }) 
        end)
    end
end

local function killAuraLoop()
    getgenv().G = true
    while getgenv().G and autoRunning do
        task.wait(0.5)
        for i,d in pairs(game.Workspace:GetDescendants()) do
            if d.ClassName == 'Humanoid' and d.Parent.Name ~= player.Name then
                d.Health = 0
            end
        end
    end
end

local function getValidNPCs()
    local npcs = {}
    local parts = Workspace:GetPartBoundsInBox(farmCenter, farmSize)
    local checked = {}
    for _, part in ipairs(parts) do
        local model = part:FindFirstAncestorOfClass("Model")
        if model and not checked[model] then
            checked[model] = true
            if isAlive(model) and not Players:GetPlayerFromCharacter(model) then
                table.insert(npcs, model)
            end
        end
    end
    table.sort(npcs, function(a, b)
        return a.HumanoidRootPart.Position.X < b.HumanoidRootPart.Position.X
    end)
    return npcs
end

local function autoSkillLoop()
    while autoRunning do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("DungeonUI") then
            
            -- Kiểm tra nếu mục tiêu cũ đã chết thì mới tìm mục tiêu mới
            if not isAlive(lockedTarget) then
                lockedTarget = nil
                local npcs = getValidNPCs()
                if #npcs > 0 then
                    local targetIndex = ((playerIndex - 1) % #npcs) + 1
                    lockedTarget = npcs[targetIndex]
                end
            end

            if isAlive(lockedTarget) then
                local targetRoot = lockedTarget.HumanoidRootPart
                local targetCF = targetRoot.CFrame
                
                -- Luôn giữ vị trí -15 stud bên dưới
                currentTargetCFrame = targetCF * CFrame.new(0, -15, 0)
                
                -- Đợi nhân vật đến vị trí ghim
                if (humanoidRootPart.Position - currentTargetCFrame.Position).Magnitude <= 15 then
                    task.wait(0.5) -- Đợi 0.5s ổn định
                    
                    -- Kiểm tra lại lần cuối trước khi tung chiêu
                    if isAlive(lockedTarget) then
                        pcall(function()
                            skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = lockedTarget.HumanoidRootPart.CFrame, Mobile = true})
                        end)
                    end
                    task.wait(0.8)
                end
            else
                currentTargetCFrame = nil
            end
        else
            lockedTarget = nil
            currentTargetCFrame = nil
        end
        task.wait(0.1)
    end
end

-- [ PHẦN GUI ]
local screenGui = player:WaitForChild("PlayerGui"):FindFirstChild("AutoSkillGui") or Instance.new("ScreenGui")
screenGui.Name = "AutoSkillGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local setupFrame = Instance.new("Frame")
setupFrame.Size = UDim2.new(0, 200, 0, 130)
setupFrame.Position = UDim2.new(0.5, -100, 0.5, -65)
setupFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
setupFrame.Active = true
setupFrame.Draggable = true
setupFrame.Parent = screenGui

local inputTextBox = Instance.new("TextBox")
inputTextBox.Size = UDim2.new(0, 160, 0, 40)
inputTextBox.Position = UDim2.new(0, 20, 0, 35)
inputTextBox.PlaceholderText = "Mã 1-100"
inputTextBox.Parent = setupFrame

local confirmBtn = Instance.new("TextButton")
confirmBtn.Size = UDim2.new(0, 160, 0, 35)
confirmBtn.Position = UDim2.new(0, 20, 0, 85)
confirmBtn.Text = "Xác nhận & Ẩn"
confirmBtn.Parent = setupFrame

local btn = screenGui:FindFirstChild("ToggleButton") or Instance.new("TextButton")
btn.Name = "ToggleButton"
btn.Size = UDim2.new(0, 150, 0, 50)
btn.Position = UDim2.new(0, 20, 0, 100)
btn.Text = "Bật Auto Skill"
btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
btn.Active = true
btn.Draggable = true
btn.Visible = false
btn.Parent = screenGui

local function toggleAuto()
    autoRunning = not autoRunning
    btn.Text = autoRunning and "Tắt Auto Skill" or "Bật Auto Skill"
    btn.BackgroundColor3 = autoRunning and Color3.fromRGB(170, 0, 0) or Color3.fromRGB(0, 170, 0)
    if autoRunning then
        task.spawn(autoSkillLoop)
        task.spawn(killAuraLoop)
        task.spawn(startScepterLoop)
    else
        getgenv().G = false
        _G.Loop = false
        lockedTarget = nil
        currentTargetCFrame = nil
    end
end

confirmBtn.MouseButton1Click:Connect(function()
    local num = tonumber(inputTextBox.Text)
    if num then
        playerIndex = num
        setupFrame.Visible = false
        btn.Visible = true
    end
end)

btn.MouseButton1Click:Connect(toggleAuto)

if AutoConfig.AutoOn then
    local assignedIndex = AutoConfig.PlayerList[player.Name]
    if assignedIndex then
        playerIndex = assignedIndex
        setupFrame.Visible = false
        btn.Visible = true
        toggleAuto() 
    end
end
