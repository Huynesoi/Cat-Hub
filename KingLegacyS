local farmCenter = CFrame.new(20072.9121, 15684.1641, 20049.5469)
local farmSize = Vector3.new(1500, 10000, 1500)
local halfFarmSize = farmSize / 2
local dungeonEntranceCF = CFrame.new(10963.3008, 133.835129, 1250.31189, 1, 0, 0, 0, 1, 0, 0, 0, 1)

local skillRemote = ReplicatedStorage:WaitForChild("Chest"):WaitForChild("Remotes"):WaitForChild("Functions"):WaitForChild("SkillAction")

local autoRunning = false
local currentTargetCFrame = nil
local playerIndex = 1

task.spawn(function()
    while true do
        if autoRunning and humanoidRootPart then
            local playerGui = player:FindFirstChild("PlayerGui")
            local dungeonUI = playerGui and playerGui:FindFirstChild("DungeonUI")
            
            if not dungeonUI then
                humanoidRootPart.CFrame = dungeonEntranceCF
                humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                task.wait(0.1)
            else
                task.wait(0.5)
            end
        else
            task.wait(1)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not autoRunning or not humanoidRootPart then return end
    
    local playerGui = player:FindFirstChild("PlayerGui")
    local dungeonUI = playerGui and playerGui:FindFirstChild("DungeonUI")
    
    if dungeonUI and currentTargetCFrame then
        humanoidRootPart.CFrame = currentTargetCFrame
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    end
end)

local function startScepterLoop()
    _G.Loop = true 
    while _G.Loop and autoRunning and task.wait(0.2) do 
        local scepCF = CFrame.new(19792.27734375, 14972.65625, 20029.33203125, 1, 0, 0, 0, 1, 0, 0, 0, 1)
        pcall(function()
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Down" }) 
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Up" }) 
        end)
    end
end

local function killAuraLoop()
    getgenv().G = true
    getgenv().Creator = 'https://discord.gg/B3HqPPzFYr - HalloweenGaster'
    while getgenv().G and getgenv().Creator == 'https://discord.gg/B3HqPPzFYr - HalloweenGaster' and autoRunning do
        task.wait(0.5)
        pcall(function()
            sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", 200)
            sethiddenproperty(game.Players.LocalPlayer, "MaxSimulationRadius", 200)
        end)
        for i,d in pairs(game.Workspace:GetDescendants()) do
            if d.ClassName == 'Humanoid' and d.Parent.Name ~= game.Players.LocalPlayer.Name then
                d.Health = 0
            end
        end
    end
end

local function getValidNPCs()
    local npcs = {}
    local parts = Workspace:GetPartBoundsInBox(farmCenter, farmSize)
    local checked = {}
    
    for _, part in ipairs(parts) do
        local model = part:FindFirstAncestorOfClass("Model")
        if model and not checked[model] then
            checked[model] = true
            local root = model:FindFirstChild("HumanoidRootPart")
            local hum = model:FindFirstChild("Humanoid")
            if root and hum and not Players:GetPlayerFromCharacter(model) and model ~= character then
                local diff = root.Position - farmCenter.Position
                if math.abs(diff.X) <= halfFarmSize.X and math.abs(diff.Y) <= halfFarmSize.Y and math.abs(diff.Z) <= halfFarmSize.Z then
                    table.insert(npcs, model)
                end
            end
        end
    end
    
    table.sort(npcs, function(a, b)
        local posA = a:FindFirstChild("HumanoidRootPart") and a.HumanoidRootPart.Position or Vector3.new()
        local posB = b:FindFirstChild("HumanoidRootPart") and b.HumanoidRootPart.Position or Vector3.new()
        return posA.X < posB.X
    end)
    
    return npcs
end

local function autoSkillLoop()
    while autoRunning do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("DungeonUI") then
            local npcs = getValidNPCs()
            
            if #npcs > 0 then
                local targetIndex = ((playerIndex - 1) % #npcs) + 1
                local targetNPC = npcs[targetIndex]
                
                if targetNPC and targetNPC:FindFirstChild("HumanoidRootPart") then
                    local targetPos = targetNPC.HumanoidRootPart.Position
                    
                    -- Cập nhật tọa độ ghim (cách 20, 20, 20 và nhìn về phía quái)
                    currentTargetCFrame = CFrame.lookAt(targetPos + Vector3.new(20, 20, 20), targetPos)
                    
                    -- Kiểm tra khoảng cách: Nếu nhân vật đã thực sự đến gần tọa độ mong muốn thì mới xả skill
                    if humanoidRootPart and (humanoidRootPart.Position - currentTargetCFrame.Position).Magnitude <= 10 then
                        pcall(function()
                            skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = targetNPC.HumanoidRootPart.CFrame, Mobile = true})
                        end)
                        task.wait(0.8) -- Delay xả chiêu
                    end
                end
            else
                currentTargetCFrame = nil
            end
        else
            currentTargetCFrame = nil
        end
        task.wait(0.1)
    end
end

