-- Các vòng lặp hỗ trợ (Scepter & KillAura)
local function startScepterLoop()
    _G.Loop = true 
    while _G.Loop and autoRunning and task.wait(0.2) do 
        local scepCF = CFrame.new(19792.27734375, 14972.65625, 20029.33203125)
        pcall(function()
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Down" }) 
            skillRemote:InvokeServer("SW_Scepters of Flame_Z", { MouseHit = scepCF, Type = "Up" }) 
        end)
    end
end

local function killAuraLoop()
    getgenv().G = true
    while getgenv().G and autoRunning do
        task.wait(0.5)
        pcall(function()
            sethiddenproperty(game.Players.LocalPlayer, "SimulationRadius", 200)
            sethiddenproperty(game.Players.LocalPlayer, "MaxSimulationRadius", 200)
        end)
        for _, d in pairs(Workspace:GetDescendants()) do
            if d.ClassName == 'Humanoid' and d.Parent.Name ~= player.Name then
                d.Health = 0
            end
        end
    end
end

-- Lấy danh sách NPC trong vùng farm (Đã fix bỏ qua NPC chết)
local function getValidNPCs()
    local npcs = {}
    local parts = Workspace:GetPartBoundsInBox(farmCenter, farmSize)
    local checked = {}
    
    for _, part in ipairs(parts) do
        local model = part:FindFirstAncestorOfClass("Model")
        if model and not checked[model] then
            checked[model] = true
            local root = model:FindFirstChild("HumanoidRootPart")
            local hum = model:FindFirstChild("Humanoid")
            -- Chỉ lấy những NPC có máu > 0
            if root and hum and hum.Health > 0 and not Players:GetPlayerFromCharacter(model) and model ~= character then
                local diff = root.Position - farmCenter.Position
                if math.abs(diff.X) <= halfFarmSize.X and math.abs(diff.Y) <= halfFarmSize.Y and math.abs(diff.Z) <= halfFarmSize.Z then
                    table.insert(npcs, model)
                end
            end
        end
    end
    
    table.sort(npcs, function(a, b)
        local posA = a.HumanoidRootPart.Position
        local posB = b.HumanoidRootPart.Position
        return posA.X < posB.X
    end)
    
    return npcs
end

-- Vòng lặp Skill chính (Đã thêm Lock NPC và Anti-KS)
local function autoSkillLoop()
    while autoRunning do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("DungeonUI") then
            
            -- Kiểm tra xem mục tiêu đang khóa có còn sống không
            if not lockedTargetNPC or not lockedTargetNPC:FindFirstChild("Humanoid") or lockedTargetNPC.Humanoid.Health <= 0 then
                lockedTargetNPC = nil -- Xóa mục tiêu cũ
                local npcs = getValidNPCs()
                
                if #npcs > 0 then
                    -- Lọc ra những NPC chưa có người chơi nào khác đứng gần (bán kính 30 studs)
                    local untargetedNPCs = {}
                    for _, npc in ipairs(npcs) do
                        local isTargetedByOther = false
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                local dist = (p.Character.HumanoidRootPart.Position - npc.HumanoidRootPart.Position).Magnitude
                                if dist < 30 then
                                    isTargetedByOther = true
                                    break
                                end
                            end
                        end
                        if not isTargetedByOther then
                            table.insert(untargetedNPCs, npc)
                        end
                    end
                    
                    -- Nếu có NPC rảnh thì ưu tiên, nếu quái bị chiếm hết thì đành đánh chung
                    local availableNPCs = #untargetedNPCs > 0 and untargetedNPCs or npcs
                    local targetIndex = ((playerIndex - 1) % #availableNPCs) + 1
                    lockedTargetNPC = availableNPCs[targetIndex]
                end
            end
            
            -- Tiến hành tấn công mục tiêu đã khóa
            if lockedTargetNPC and lockedTargetNPC:FindFirstChild("HumanoidRootPart") then
                local targetPos = lockedTargetNPC.HumanoidRootPart.Position
                
                -- Cập nhật tọa độ ghim (nhìn về phía quái)
                currentTargetCFrame = CFrame.lookAt(targetPos + Vector3.new(20, 20, 20), targetPos)
                
                -- Kiểm tra khoảng cách để bắt đầu xả skill
                if humanoidRootPart and (humanoidRootPart.Position - currentTargetCFrame.Position).Magnitude <= 10 then
                    task.wait(0.5) 
                    
                    -- Chắc chắn NPC vẫn còn sống trước khi xả chiêu
                    if lockedTargetNPC:FindFirstChild("HumanoidRootPart") and lockedTargetNPC.Humanoid.Health > 0 then
                        pcall(function()
                            skillRemote:InvokeServer("DF_GoldGold_V", {
                                MouseHit = lockedTargetNPC.HumanoidRootPart.CFrame, 
                                Mobile = true
                            })
                        end)
                    end
                    task.wait(0.3)
                end
            else
                currentTargetCFrame = nil
            end
        else
            currentTargetCFrame = nil
        end
        task.wait(0.1)
    end
end

