local function toggleAuto()
    autoRunning = not autoRunning
    btn.Text = autoRunning and "Tắt Auto Skill" or "Bật Auto Skill"
    btn.BackgroundColor3 = autoRunning and Color3.fromRGB(170, 0, 0) or Color3.fromRGB(0, 170, 0)
    
    if autoRunning then
        task.spawn(autoSkillLoop)
        task.spawn(killAuraLoop)
        task.spawn(startScepterLoop)
    else
        getgenv().G = false
        _G.Loop = false
        currentTargetCFrame = nil
    end
end

