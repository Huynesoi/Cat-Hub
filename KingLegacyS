local function autoSkillLoop()
    while autoRunning do
        local playerGui = player:FindFirstChild("PlayerGui")
        if playerGui and playerGui:FindFirstChild("DungeonUI") then
            
            -- KIỂM TRA MỤC TIÊU HIỆN TẠI: Nếu nó còn sống và tồn tại thì không đổi mục tiêu
            local isTargetValid = myCurrentTargetNPC and myCurrentTargetNPC.Parent and 
                                 myCurrentTargetNPC:FindFirstChild("Humanoid") and 
                                 myCurrentTargetNPC.Humanoid.Health > 0 and
                                 myCurrentTargetNPC:FindFirstChild("HumanoidRootPart")

            if not isTargetValid then
                myCurrentTargetNPC = nil
                currentTargetCFrame = nil
                
                local npcs = getValidNPCs()
                if #npcs > 0 then
                    -[span_11](start_span)- Chỉ khi quái cũ chết mới dùng modulo để chọn quái mới[span_11](end_span)
                    local targetIndex = ((playerIndex - 1) % #npcs) + 1
                    myCurrentTargetNPC = npcs[targetIndex]
                end
            end

            -- NẾU ĐÃ CÓ MỤC TIÊU THÌ TẤN CÔNG
            if myCurrentTargetNPC and myCurrentTargetNPC:FindFirstChild("HumanoidRootPart") then
                local targetCF = myCurrentTargetNPC.HumanoidRootPart.CFrame
                
                -[span_12](start_span)- Luôn ghim vị trí ở dưới quái 15 stud[span_12](end_span)
                currentTargetCFrame = targetCF * CFrame.new(0, -15, 0)
                
                -- Kiểm tra xem đã tiếp cận điểm ghim chưa (sai số 10 stud)
                if humanoidRootPart and (humanoidRootPart.Position - currentTargetCFrame.Position).Magnitude <= 10 then
                    
                    [span_13](start_span)task.wait(0.5) -- Đợi 0.5s để ổn định vị trí theo yêu cầu[span_13](end_span)
                    
                    -- Lấy tọa độ quái một lần nữa ngay lúc này để tránh đánh lệch
                    if myCurrentTargetNPC and myCurrentTargetNPC:FindFirstChild("HumanoidRootPart") then
                        local exactTargetCF = myCurrentTargetNPC.HumanoidRootPart.CFrame
                        pcall(function()
                            [span_14](start_span)skillRemote:InvokeServer("DF_GoldGold_V", {MouseHit = exactTargetCF, Mobile = true})[span_14](end_span)
                        end)
                    end
                    [span_15](start_span)task.wait(0.8) -- Delay chống spam[span_15](end_span)
                end
            end
        else
            myCurrentTargetNPC = nil
            currentTargetCFrame = nil
        end
        task.wait(0.1)
    end
end

